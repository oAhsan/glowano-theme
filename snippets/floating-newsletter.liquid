<div class="glw-float-newsletter" aria-hidden="true">
  <button
    type="button"
    class="glw-float-newsletter__button"
    aria-label="Join our newsletter"
  >
    <span class="glw-float-newsletter__icon">✉️</span>
  </button>

  <div class="glw-float-newsletter__backdrop" hidden></div>

  <div
    class="glw-float-newsletter__modal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="glw-float-newsletter-title"
    hidden
  >
    <div class="glw-float-newsletter__modal-inner">
      <button
        type="button"
        class="glw-float-newsletter__close"
        aria-label="Close newsletter signup"
      >
        ×
      </button>

      <h3 id="glw-float-newsletter-title" class="glw-float-newsletter__title">
        Stay in the Glow
      </h3>
      <p class="glw-float-newsletter__text">
        Join our list for early access to launches, offers, and glow‑up tips.
      </p>

      {%- form 'customer', id: 'glw-float-newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter,floating-modal">
        <div class="glw-float-newsletter__field">
          <input
            id="glw-float-newsletter-email"
            class="glw-float-newsletter__input"
            type="email"
            name="contact[email]"
            required
            autocomplete="email"
            placeholder="Enter your email"
          >
        </div>
        <button type="submit" class="glw-float-newsletter__submit">
          Subscribe
        </button>
        {%- if form.errors -%}
          <p class="glw-float-newsletter__message glw-float-newsletter__message--error">
            {{ form.errors.translated_fields['email'] | capitalize }} {{ form.errors.messages['email'] }}
          </p>
        {%- elsif form.posted_successfully? -%}
          <p class="glw-float-newsletter__message glw-float-newsletter__message--success">
            {{ 'newsletter.success' | t }}
          </p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

<style>
  .glw-float-newsletter {
    position: fixed;
    inset-inline-end: 1.6rem;
    inset-block-end: 1.6rem;
    z-index: 60;
    pointer-events: none;
  }

  .glw-float-newsletter__button {
    pointer-events: auto;
    border: none;
    border-radius: 999px;
    padding: 0.9rem 1.4rem;
    background: linear-gradient(135deg, #f6d889, #c79b3a);
    color: #121212;
    font-size: 1.4rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    box-shadow:
      0 10px 28px rgba(0, 0, 0, 0.55),
      0 0 0 1px rgba(255, 224, 140, 0.6);
    cursor: pointer;
    transition:
      transform 150ms ease-out,
      box-shadow 150ms ease-out,
      filter 150ms ease-out,
      background 150ms ease-out;
  }

  .glw-float-newsletter__icon {
    font-size: 1.5rem;
  }

  @media (hover: hover) {
    .glw-float-newsletter__button:hover {
      transform: translateY(-1px);
      box-shadow:
        0 14px 34px rgba(0, 0, 0, 0.7),
        0 0 0 1px rgba(255, 224, 140, 0.9);
      filter: brightness(1.03);
    }

    .glw-float-newsletter__button:active {
      transform: translateY(0);
      box-shadow:
        0 8px 22px rgba(0, 0, 0, 0.8),
        0 0 0 1px rgba(255, 224, 140, 0.7);
    }
  }

  .glw-float-newsletter__backdrop {
    pointer-events: auto;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.35);
    opacity: 0;
    transition: opacity 180ms ease-out;
  }

  .glw-float-newsletter__backdrop.is-active {
    opacity: 1;
  }

  .glw-float-newsletter__modal {
    pointer-events: none;
    position: fixed;
    inset-inline: 1.2rem;
    inset-block-end: 1.2rem;
    max-width: 360px;
    margin-inline: auto;
    transform: translateY(16px);
    opacity: 0;
    transition:
      transform 220ms ease-out,
      opacity 220ms ease-out;
  }

  .glw-float-newsletter__modal.is-active {
    pointer-events: auto;
    opacity: 1;
    transform: translateY(0);
  }

  .glw-float-newsletter__modal-inner {
    position: relative;
    border-radius: 1.2rem;
    padding: 1.8rem 1.6rem 1.6rem;
    background: rgba(10, 10, 10, 0.98);
    color: #f6f3e8;
    box-shadow:
      0 24px 70px rgba(0, 0, 0, 0.9),
      0 0 0 1px rgba(255, 224, 140, 0.12);
  }

  .glw-float-newsletter__close {
    position: absolute;
    inset-block-start: 0.6rem;
    inset-inline-end: 0.6rem;
    border: none;
    background: transparent;
    color: rgba(246, 243, 232, 0.7);
    font-size: 1.8rem;
    line-height: 1;
    cursor: pointer;
  }

  .glw-float-newsletter__title {
    margin: 0 0 0.4rem;
    font-size: 1.6rem;
    font-weight: 600;
  }

  .glw-float-newsletter__text {
    margin: 0 0 1.2rem;
    font-size: 1.3rem;
    color: rgba(246, 243, 232, 0.85);
  }

  .glw-float-newsletter__field {
    margin-bottom: 0.9rem;
  }

  .glw-float-newsletter__input {
    width: 100%;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.24);
    background: rgba(0, 0, 0, 0.6);
    color: #f6f3e8;
    padding: 0.7rem 1.2rem;
    font-size: 1.3rem;
  }

  .glw-float-newsletter__input::placeholder {
    color: rgba(246, 243, 232, 0.5);
  }

  .glw-float-newsletter__submit {
    width: 100%;
    border-radius: 999px;
    border: none;
    padding: 0.8rem 1.2rem;
    background: linear-gradient(135deg, #f6d889, #c79b3a);
    color: #121212;
    font-weight: 600;
    font-size: 1.3rem;
    cursor: pointer;
  }

  .glw-float-newsletter__message {
    margin: 0.6rem 0 0;
    font-size: 1.2rem;
  }

  .glw-float-newsletter__message--success {
    color: #8ee6a3;
  }

  .glw-float-newsletter__message--error {
    color: #ffb3b3;
  }

  @media screen and (max-width: 749px) {
    .glw-float-newsletter {
      inset-inline-end: 1.2rem;
      inset-block-end: 1.2rem;
    }
  }
</style>

<script>
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      var root = document.querySelector('.glw-float-newsletter');
      if (!root) return;

      var openButton = root.querySelector('.glw-float-newsletter__button');
      var backdrop = root.querySelector('.glw-float-newsletter__backdrop');
      var modal = root.querySelector('.glw-float-newsletter__modal');
      var closeButton = root.querySelector('.glw-float-newsletter__close');

      function openModal() {
        if (!modal || !backdrop) return;
        modal.hidden = false;
        backdrop.hidden = false;
        modal.classList.add('is-active');
        backdrop.classList.add('is-active');
      }

      function closeModal() {
        if (!modal || !backdrop) return;
        modal.classList.remove('is-active');
        backdrop.classList.remove('is-active');
        window.setTimeout(function () {
          modal.hidden = true;
          backdrop.hidden = true;
        }, 220);
      }

      if (openButton) {
        openButton.addEventListener('click', openModal);
      }
      if (closeButton) {
        closeButton.addEventListener('click', closeModal);
      }
      if (backdrop) {
        backdrop.addEventListener('click', closeModal);
      }
    });
  })();
</script>

