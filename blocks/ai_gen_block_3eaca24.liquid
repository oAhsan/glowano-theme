{% doc %}
  @prompt
    Design a professional, minimalist countdown timer block for a limited-time sale. The block should display days, hours, minutes, and seconds in a horizontal, evenly spaced layout that is easy to read at a glance. Use modern sans-serif fonts, subtle font weights, and a neutral or monochrome color palette with optional accent for urgency (like a subtle red or orange). Include a concise headline above the timer, e.g., ‘Sale Ends In,’ and optional small subtext, e.g., ‘Hurry, limited stock!’ The countdown should update in real-time, and near the end (last 24 hours), it can optionally change color to draw attention. Make sure the block is fully responsive, centered on mobile, and aligned neatly on desktop. Add padding and spacing to prevent crowding. Avoid unnecessary animations or large background graphics. Ensure the block integrates seamlessly with sticky or transparent headers without overlapping. Provide easy settings for changing countdown duration, fonts, colors, alignment, and headline text
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.alignment }};
    position: relative;
    z-index: 1;
  }

  .ai-countdown-timer-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-countdown-timer-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: {{ block.settings.headline_weight }};
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    font-family: {{ block.settings.headline_font.family }}, {{ block.settings.headline_font.fallback_families }};
    letter-spacing: 0.5px;
  }

  .ai-countdown-timer-display-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.alignment }};
    gap: {{ block.settings.timer_gap }}px;
    flex-wrap: wrap;
    margin-bottom: {{ block.settings.subtext_spacing }}px;
  }

  .ai-countdown-timer-unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.unit_min_width }}px;
  }

  .ai-countdown-timer-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.timer_size }}px;
    font-weight: {{ block.settings.timer_weight }};
    color: {{ block.settings.timer_color }};
    font-family: {{ block.settings.timer_font.family }}, {{ block.settings.timer_font.fallback_families }};
    line-height: 1.2;
    margin-bottom: 8px;
    transition: color 0.3s ease;
  }

  .ai-countdown-timer-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    font-weight: {{ block.settings.label_weight }};
    color: {{ block.settings.label_color }};
    text-transform: uppercase;
    letter-spacing: 1px;
    font-family: {{ block.settings.timer_font.family }}, {{ block.settings.timer_font.fallback_families }};
  }

  .ai-countdown-timer-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0;
  }

  .ai-countdown-timer-{{ ai_gen_id }}.urgent .ai-countdown-timer-value-{{ ai_gen_id }} {
    color: {{ block.settings.urgent_color }};
  }

  .ai-countdown-timer-{{ ai_gen_id }}.urgent .ai-countdown-timer-headline-{{ ai_gen_id }} {
    color: {{ block.settings.urgent_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
      text-align: center;
    }

    .ai-countdown-timer-display-{{ ai_gen_id }} {
      justify-content: center;
      gap: {{ block.settings.timer_gap | times: 0.7 }}px;
    }

    .ai-countdown-timer-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.8 }}px;
    }

    .ai-countdown-timer-value-{{ ai_gen_id }} {
      font-size: {{ block.settings.timer_size | times: 0.7 }}px;
    }

    .ai-countdown-timer-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.8 }}px;
    }

    .ai-countdown-timer-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }

    .ai-countdown-timer-unit-{{ ai_gen_id }} {
      min-width: {{ block.settings.unit_min_width | times: 0.7 }}px;
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  data-urgent-hours="{{ block.settings.urgent_hours }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-countdown-timer-container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-countdown-timer-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    <div class="ai-countdown-timer-display-{{ ai_gen_id }}">
      {% if block.settings.show_days %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-days>00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.days_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_hours %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-hours>00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_minutes %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-minutes>00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.minutes_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_seconds %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-seconds>00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.seconds_label }}</div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.subtext != blank %}
      <p class="ai-countdown-timer-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.urgentHours = parseInt(this.dataset.urgentHours);
        this.daysEl = this.querySelector('[data-days]');
        this.hoursEl = this.querySelector('[data-hours]');
        this.minutesEl = this.querySelector('[data-minutes]');
        this.secondsEl = this.querySelector('[data-seconds]');
      }

      connectedCallback() {
        this.updateCountdown();
        this.interval = setInterval(() => this.updateCountdown(), 1000);
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      updateCountdown() {
        const endDateTime = new Date(this.endDate + 'T' + this.endTime).getTime();
        const now = new Date().getTime();
        const distance = endDateTime - now;

        if (distance < 0) {
          this.handleExpired();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        if (this.daysEl) this.daysEl.textContent = String(days).padStart(2, '0');
        if (this.hoursEl) this.hoursEl.textContent = String(hours).padStart(2, '0');
        if (this.minutesEl) this.minutesEl.textContent = String(minutes).padStart(2, '0');
        if (this.secondsEl) this.secondsEl.textContent = String(seconds).padStart(2, '0');

        const totalHours = days * 24 + hours;
        if (totalHours <= this.urgentHours) {
          this.classList.add('urgent');
        } else {
          this.classList.remove('urgent');
        }
      }

      handleExpired() {
        if (this.daysEl) this.daysEl.textContent = '00';
        if (this.hoursEl) this.hoursEl.textContent = '00';
        if (this.minutesEl) this.minutesEl.textContent = '00';
        if (this.secondsEl) this.secondsEl.textContent = '00';
        if (this.interval) {
          clearInterval(this.interval);
        }
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

