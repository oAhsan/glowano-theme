{% doc %}
  @prompt
    Create a custom Shopify section for a banner image with two clickable animated hotspots.
    
    Hotspots should have a subtle pulsing animation to attract attention without being distracting.
    
    When a hotspot is clicked, a sleek slide-in product card should appear from the bottom of the screen.
    
    The slide-in card must include:
    
    Product image (average/medium size, not fullscreen).
    
    Product title.
    
    Product price.
    
    Add-to-cart button.
    
    A close ❌ button in the top-right of the card.
    
    Ability to close the card by tapping anywhere outside the card.
    
    Both the product image and the product title should be clickable links to the product page.
    
    Theme editor customization options:
    
    Banner background image.
    
    Hotspot positions (x, y).
    
    Assign products to hotspots.
    
    Background color, text size, button style for the card.
    
    Behavior:
    
    Hotspots must stay fixed in position on the banner, even when resizing the screen.
    
    Below the banner image, include a customizable rich text area for brand messaging or product highlights., Update the code so that:
    
    The slide-in product card also closes when the user taps/clicks anywhere outside of the card. Use a semi-transparent overlay behind the card, and make sure clicks inside the card (on the image, title, or add-to-cart button) do not close it.
    
    Prevent the banner image from zooming or scaling when a hotspot is clicked. The hotspot click should only trigger the slide-in card, with no visual effect on the banner image.
    
    Keep all other existing functionality and theme editor options unchanged., add this java script document.addEventListener("click", function(event) {
      const productCard = document.querySelector(".slide-in-card");
      const isCardOpen = productCard && productCard.classList.contains("active");
    
      if (isCardOpen && !productCard.contains(event.target)) {
        productCard.classList.remove("active");
      }
    });, that java script should work for both hotspts and when i click on hotspots the image should not zoom in

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-hotspots-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: 100%;
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;user-select: none;
    pointer-events: none;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 400px;
  }

  .ai-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hotspot-{{ ai_gen_id }} {
    position: absolute;
    top: var(--ai-hotspot-y-{{ ai_gen_id }});
    left: var(--ai-hotspot-x-{{ ai_gen_id }});
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .ai-hotspot-button-{{ ai_gen_id }} {
    width: {{ block.settings.hotspot_size }}px;
    height: {{ block.settings.hotspot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.hotspot_color }};
    border: 2px solid {{ block.settings.hotspot_border_color }};
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: {{ block.settings.hotspot_icon_color }};
    animation: ai-hotspot-pulse-{{ ai_gen_id }} 2s infinite;
    transition: transform 0.2s ease;
  }

  .ai-hotspot-button-{{ ai_gen_id }}:hover {
    transform: scale(1.05);
  }

  .ai-hotspot-button-{{ ai_gen_id }}:active {
    transform: scale(0.95);
  }

  @keyframes ai-hotspot-pulse-{{ ai_gen_id }} {
    0% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.1);
      opacity: 0.8;
    }
    100% {
      transform: scale(1);
      opacity: 1;
    }
  }

  .ai-hotspot-button-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.hotspot_size }}px * 0.5);
    height: calc({{ block.settings.hotspot_size }}px * 0.5);
  }

  .ai-product-card-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-product-card-overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-product-card-{{ ai_gen_id }} {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(100%);
    width: 90%;
    max-width: 400px;
    background-color: {{ block.settings.card_bg_color }};
    border-radius: 16px 16px 0 0;
    padding: 24px;
    z-index: 1001;
    transition: transform 0.4s ease;
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.15);
  }

  .ai-product-card-{{ ai_gen_id }}.active {
    transform: translateX(-50%) translateY(0);
  }

  .ai-product-card-close-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.card_text_color }};
    opacity: 0.7;
    border-radius: 50%;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-card-close-{{ ai_gen_id }}:hover {
    opacity: 1;
    background-color: rgba(0, 0, 0, 0.1);
  }

  .ai-product-card-content-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    width: 100px;
    height: 100px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
  }

  .ai-product-card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-card-info-{{ ai_gen_id }} {
    flex-grow: 1;
    padding-right: 24px;
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ block.settings.card_text_color }};text-decoration: none;
    display: block;
  }

  .ai-product-card-title-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_price_size }}px;
    margin-bottom: 16px;
    color: {{ block.settings.card_text_color }};
  }

  .ai-product-card-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 24px;
    background-color: {{ block.settings.card_button_color }};
    color: {{ block.settings.card_button_text_color }};
    border: none;
    border-radius: {{ block.settings.card_button_radius }}px;
    font-size: {{ block.settings.card_button_text_size }}px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-product-card-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.card_button_hover_color }};
  }

  .ai-banner-text-{{ ai_gen_id }} {
    padding: 40px 20px;
    text-align: center;
    color: {{ block.settings.text_color }};background-color: {{ block.settings.text_bg_color }};
  }

  .ai-banner-text-{{ ai_gen_id }} p {
    margin: 0 0 16px;
    font-size: {{ block.settings.text_size }}px;
  }

  .ai-banner-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-empty-product-{{ ai_gen_id }} {
    text-align: center;
    padding: 20px;
    color: #999;
    font-style: italic;
  }

  @media screen and (max-width: 749px) {
    .ai-product-card-{{ ai_gen_id }} {
      width: 95%;
      padding: 20px;
    }

    .ai-product-card-content-{{ ai_gen_id }} {
      gap: 12px;
    }

    .ai-product-card-image-{{ ai_gen_id }} {
      width: 80px;
      height: 80px;
    }

    .ai-hotspot-button-{{ ai_gen_id }} {
      width: calc({{ block.settings.hotspot_size }}px * 0.8);
      height: calc({{ block.settings.hotspot_size }}px * 0.8);
    }
  }
{% endstyle %}

<banner-hotspots-{{ ai_gen_id }}
  class="ai-banner-hotspots-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-banner-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.banner_image %}
      <img
        src="{{ block.settings.banner_image | image_url: width: 2000 }}"
        alt="{{ block.settings.banner_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.banner_image.width }}"
        height="{{ block.settings.banner_image.height }}"
        class="ai-banner-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-banner-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}<div class="ai-banner-empty-state-{{ ai_gen_id }}">
          Add a banner image to get started
        </div>
      </div>
    {% endif %}

    {% for i in (1..2) %}
      {% liquid
        assign hotspot_x_key = 'hotspot_' | append: i | append: '_x'
        assign hotspot_y_key = 'hotspot_' | append: i | append: '_y'
        assign product_key = 'hotspot_' | append: i | append: '_product'

        assign hotspot_x = block.settings[hotspot_x_key]
        assign hotspot_y = block.settings[hotspot_y_key]
        assign product = block.settings[product_key]%}

      <div
        class="ai-hotspot-{{ ai_gen_id }} ai-hotspot-{{ ai_gen_id }}-{{ i }}"
        style="
          --ai-hotspot-x-{{ ai_gen_id }}: {{ hotspot_x }}%;
          --ai-hotspot-y-{{ ai_gen_id }}: {{ hotspot_y }}%;
        "
        data-hotspot-id="{{ i }}"
      >
        <button
          class="ai-hotspot-button-{{ ai_gen_id }}"
          aria-label="View product details"
          type="button"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
        </button></div>
    {% endfor %}
  </div>

  {% if block.settings.banner_text != blank %}
    <div class="ai-banner-text-{{ ai_gen_id }}">
      {{ block.settings.banner_text }}
    </div>
  {% endif %}

  <div class="ai-product-card-overlay-{{ ai_gen_id }}"></div>

  {% for i in (1..2) %}
    {% liquid
      assign product_key = 'hotspot_' | append: i | append: '_product'
      assign product = block.settings[product_key]
    %}

    <div
      class="ai-product-card-{{ ai_gen_id }} ai-product-card-{{ ai_gen_id }}-{{ i }}"
      data-product-card="{{ i }}"
    >
      <button
        class="ai-product-card-close-{{ ai_gen_id }}"
        aria-label="Close"
        type="button"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      {% if product != blank %}
        <div class="ai-product-card-content-{{ ai_gen_id }}"><a
            href="{{ product.url }}"
            class="ai-product-card-image-{{ ai_gen_id }}"
          >
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 200 }}"
                alt="{{ product.featured_image.alt | escape }}"
                width="200"
                height="200"
                loading="lazy"
              >
            {% else %}
              <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </a>
          <div class="ai-product-card-info-{{ ai_gen_id }}">
            <a
              href="{{ product.url }}"
              class="ai-product-card-title-{{ ai_gen_id }}"
            >
              {{ product.title }}
            </a>
            <div class="ai-product-card-price-{{ ai_gen_id }}">
              {{ product.price | money }}
            </div>
          </div>
        </div>
        <form action="/cart/add" method="post" enctype="multipart/form-data">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <button
            type="submit"
            class="ai-product-card-button-{{ ai_gen_id }}"
          >
            {{ block.settings.add_to_cart_text }}
          </button>
        </form>
      {% else %}
        <div class="ai-empty-product-{{ ai_gen_id }}">
          Select a product for this hotspot
        </div>
      {% endif %}
    </div>
  {% endfor %}
</banner-hotspots-{{ ai_gen_id }}><script>
  (function() {
    class BannerHotspots{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.hotspots = this.querySelectorAll('.ai-hotspot-{{ ai_gen_id }}');
        this.overlay = this.querySelector('.ai-product-card-overlay-{{ ai_gen_id }}');
        this.productCards = this.querySelectorAll('.ai-product-card-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.hotspots.forEach((hotspot) => {
          const button = hotspot.querySelector('.ai-hotspot-button-{{ ai_gen_id }}');
          const hotspotId = hotspot.dataset.hotspotId;
          const productCard = this.querySelector(`[data-product-card="${hotspotId}"]`);

          button.addEventListener('click', (event) => {
            event.preventDefault();
            event.stopPropagation();
            this.showProductCard(productCard);
          });
        });

        this.productCards.forEach((card) => {
          const closeButton = card.querySelector('.ai-product-card-close-{{ ai_gen_id }}');
          closeButton.addEventListener('click', (event) => {
            event.preventDefault();
            event.stopPropagation();
            this.hideProductCard(card);
          });

          card.addEventListener('click', (event) => {
            event.stopPropagation();
          });
        });

        this.overlay.addEventListener('click', (event) => {
          event.preventDefault();
          this.hideAllProductCards();
        });document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape') {
            this.hideAllProductCards();
          }
        });document.addEventListener("click", (event) => {
          const activeCard = document.querySelector(".ai-product-card-{{ ai_gen_id }}.active");
          const isCardOpen = activeCard && activeCard.classList.contains("active");

          if (isCardOpen && !activeCard.contains(event.target) && !event.target.closest('.ai-hotspot-button-{{ ai_gen_id }}')) {
            this.hideAllProductCards();
          }
        });
      }

      showProductCard(card) {
        this.hideAllProductCards();
        this.overlay.classList.add('active');
        card.classList.add('active');document.body.style.overflow = 'hidden';
      }

      hideProductCard(card) {
        card.classList.remove('active');
        this.overlay.classList.remove('active');
        document.body.style.overflow = '';
      }

      hideAllProductCards() {
        this.productCards.forEach((card) => {
          card.classList.remove('active');
        });
        this.overlay.classList.remove('active');
        document.body.style.overflow = '';
      }
    }

    customElements.define('banner-hotspots-{{ ai_gen_id }}', BannerHotspots{{ ai_gen_id }});
  })();
</script>

