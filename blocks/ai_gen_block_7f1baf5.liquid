{% doc %}
  @prompt
    Create a clean, minimalist, and modern Shopify AI block that displays a countdown timer for a limited-time sale, designed to create urgency and encourage purchases. The block should feature a clear, legible countdown showing days, hours, minutes, and seconds, with smooth real-time updating. Use a simple color palette that fits with a clean design—preferably neutral or monochrome—without distracting elements. Include a concise headline like ‘Sale Ends In’ and an optional short subtext like ‘Hurry, limited stock!’ The block must be fully responsive for mobile, tablet, and desktop screens. Provide easy customization options for colors, fonts, countdown duration, and alignment. Ensure the block is visually balanced, with sufficient spacing, and integrates seamlessly with any Shopify theme. Avoid unnecessary animations, clutter, or graphics; focus on clarity and urgency. The block should also be compatible with sticky headers or transparent headers if placed at the top of a page, and it should remain fully functional if duplicated elsewhere on the store.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-countdown-timer-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-countdown-timer-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-countdown-timer-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: {{ block.settings.headline_weight }};
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    letter-spacing: {{ block.settings.letter_spacing }}px;
  }

  .ai-countdown-timer-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0 0 {{ block.settings.subtext_spacing }}px;
  }

  .ai-countdown-timer-display-{{ ai_gen_id }} {
    display: flex;
    justify-content: {{ block.settings.text_alignment }};
    gap: {{ block.settings.timer_gap }}px;
    flex-wrap: wrap;
  }

  .ai-countdown-timer-unit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: {{ block.settings.unit_min_width }}px;
  }

  .ai-countdown-timer-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: {{ block.settings.number_weight }};
    color: {{ block.settings.number_color }};
    line-height: 1;
    margin-bottom: {{ block.settings.label_spacing }}px;
    font-variant-numeric: tabular-nums;
  }

  .ai-countdown-timer-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.label_size }}px;
    color: {{ block.settings.label_color }};
    text-transform: {{ block.settings.label_transform }};
    letter-spacing: {{ block.settings.label_letter_spacing }}px;
  }

  .ai-countdown-timer-expired-{{ ai_gen_id }} {
    font-size: {{ block.settings.expired_size }}px;
    color: {{ block.settings.expired_color }};
    font-weight: {{ block.settings.expired_weight }};
  }

  @media screen and (max-width: 749px) {
    .ai-countdown-timer-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-countdown-timer-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.8 }}px;
    }

    .ai-countdown-timer-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }

    .ai-countdown-timer-value-{{ ai_gen_id }} {
      font-size: {{ block.settings.number_size | times: 0.7 }}px;
    }

    .ai-countdown-timer-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.label_size | times: 0.9 }}px;
    }

    .ai-countdown-timer-display-{{ ai_gen_id }} {
      gap: {{ block.settings.timer_gap | times: 0.7 }}px;
    }

    .ai-countdown-timer-unit-{{ ai_gen_id }} {
      min-width: {{ block.settings.unit_min_width | times: 0.8 }}px;
    }
  }
{% endstyle %}

<countdown-timer-{{ ai_gen_id }}
  class="ai-countdown-timer-{{ ai_gen_id }}"
  data-end-date="{{ block.settings.end_date }}"
  data-end-time="{{ block.settings.end_time }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-countdown-timer-container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-countdown-timer-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-countdown-timer-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}

    <div class="ai-countdown-timer-display-{{ ai_gen_id }}" data-timer-display>
      {% if block.settings.show_days %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-days>00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.days_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_hours %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-hours>00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.hours_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_minutes %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-minutes>00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.minutes_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.show_seconds %}
        <div class="ai-countdown-timer-unit-{{ ai_gen_id }}">
          <div class="ai-countdown-timer-value-{{ ai_gen_id }}" data-seconds>00</div>
          <div class="ai-countdown-timer-label-{{ ai_gen_id }}">{{ block.settings.seconds_label }}</div>
        </div>
      {% endif %}
    </div>

    <div class="ai-countdown-timer-expired-{{ ai_gen_id }}" data-expired-message style="display: none;">
      {{ block.settings.expired_message }}
    </div>
  </div>
</countdown-timer-{{ ai_gen_id }}>

<script>
  (function() {
    class CountdownTimer{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.endDate = this.dataset.endDate;
        this.endTime = this.dataset.endTime;
        this.timerDisplay = this.querySelector('[data-timer-display]');
        this.expiredMessage = this.querySelector('[data-expired-message]');
        this.daysEl = this.querySelector('[data-days]');
        this.hoursEl = this.querySelector('[data-hours]');
        this.minutesEl = this.querySelector('[data-minutes]');
        this.secondsEl = this.querySelector('[data-seconds]');
        this.interval = null;
      }

      connectedCallback() {
        if (!this.endDate) {
          this.showExpired();
          return;
        }

        this.startCountdown();
      }

      disconnectedCallback() {
        if (this.interval) {
          clearInterval(this.interval);
        }
      }

      startCountdown() {
        this.updateCountdown();
        this.interval = setInterval(() => {
          this.updateCountdown();
        }, 1000);
      }

      updateCountdown() {
        const endDateTime = this.getEndDateTime();
        const now = new Date().getTime();
        const distance = endDateTime - now;

        if (distance < 0) {
          this.showExpired();
          return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        if (this.daysEl) this.daysEl.textContent = this.padZero(days);
        if (this.hoursEl) this.hoursEl.textContent = this.padZero(hours);
        if (this.minutesEl) this.minutesEl.textContent = this.padZero(minutes);
        if (this.secondsEl) this.secondsEl.textContent = this.padZero(seconds);
      }

      getEndDateTime() {
        const dateStr = this.endDate;
        const timeStr = this.endTime || '23:59';
        const dateTimeStr = dateStr + 'T' + timeStr + ':00';
        return new Date(dateTimeStr).getTime();
      }

      padZero(num) {
        return num.toString().padStart(2, '0');
      }

      showExpired() {
        if (this.interval) {
          clearInterval(this.interval);
        }
        if (this.timerDisplay) {
          this.timerDisplay.style.display = 'none';
        }
        if (this.expiredMessage) {
          this.expiredMessage.style.display = 'block';
        }
      }
    }

    customElements.define('countdown-timer-{{ ai_gen_id }}', CountdownTimer{{ ai_gen_id }});
  })();
</script>

