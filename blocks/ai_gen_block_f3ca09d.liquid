{% doc %}
  @prompt
    Create a TikTok-style horizontal video carousel section for Shopify (videos from Shopify Files). Make it infinite/looping and mobile responsive. Fix these behaviors precisely:
    
    Only the center video plays; all others are fully paused (no play overlays or preview motion).
    
    The carousel must be seamless infinite (use cloning/continuous scroll so arrows never jump back to start).
    
    Click/tap anywhere on side video including buttons → it smoothly slides to center and immediately starts playing; the previous center pauses.
    
    Click/tap anywhere on a video (except buttons) toggles play/pause for that video (if tapped on a side video this action first brings it to center then toggles appropriately).
    
    There are two small round control buttons placed horizontally side-by-side on each video: Pause/Play and Mute.
    
    If the Mute state is changed on any video it becomes a global mute/unmute (all videos update instantly).
    
    The initial mute state must be correct in UI (no mismatch — if videos start muted, the buttons show muted).
    
    Debounce button actions so quick repeated taps can’t desync state.
    
    If you tap the Pause button on a non-center video, that video must first move to center, then perform the pause/play action (so pause always affects the center).
    
    Add two full arrow buttons at bottom-center for manual navigation (simple arrow icons, no container).
    
    Smooth transitions, safe click debouncing, and center-detection (IntersectionObserver or equivalent) to ensure only one video plays.
    
    Make the section highly customizable in theme editor 
    
    Accessibility: keyboard focus, aria labels for buttons, and reduced-motion preference respected., Fix the horizontal scroll and blinking issue in the TikTok-style video carousel section.
    
    Remove any unwanted horizontal page scroll — the carousel must stay fully contained inside the section width (no overflow).
    
    Use overflow hidden on the main container so the section doesn’t stretch the page.
    
    Make the infinite loop smooth, without any visible blink, refresh, or jump at the end — it should seamlessly loop using cloned slides or continuous translation (no reset effect).
    
    Ensure arrow clicks and swipe gestures move smoothly between videos without snapping or visible reset.
    
    Keep only one active video in play at a time.
    
    Maintain all previous behaviors (center auto-play, side pause, global mute, horizontal buttons, etc.).
    
    The section must stay responsive, lightweight, and fully customizable in the theme editor., Fix the carousel so when jumping between the last and first video there’s no lag or blink, and whenever I tap anywhere on a side video (including its buttons) it should smoothly move to the center and start playing automatically. make the whole section highly customizable , there should always be a vid at center playing, if i tap mute button on side vid it should come at center and start playing, Fix the carousel so when looping from last to first video it keeps playing smoothly without stopping, and when I tap the mute button on a side video, it should only bring that video to the center without muting it., Add customization controls for main video scale, section padding (top and bottom), and make all animations and transitions ultra-smooth with no lag or snapping between videos.
    , Make it so that tapping on the center (main) video pauses or plays it, and add a customizable transition speed or easing curve control for ultra-smooth, TikTok-like motion. make the navigation icon customizable, Fix the bug where tapping the first video after reaching the end makes the carousel get stuck — it should loop seamlessly and play the tapped video normally, just like when using the manual navigation arrows., Fix the carousel so when I tap on the first or last video, it slides smoothly to center without spinning the whole loop — it should behave exactly like the arrow buttons with no extra rotation or delay., Fix the carousel so that when switching between the last and first video, the thumbnails don’t reset to their first frame — each paused video should keep showing its last paused frame instead of restarting.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-tiktok-carousel-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-tiktok-carousel__wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    overflow: hidden;
  }

  .ai-tiktok-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.video_gap }}px;
    {% if block.settings.transition_easing == 'smooth' %}
      transition: transform {{ block.settings.transition_speed | divided_by: 1000.0 }}s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    {% elsif block.settings.transition_easing == 'snappy' %}
      transition: transform {{ block.settings.transition_speed | divided_by: 1000.0 }}s cubic-bezier(0.4, 0, 0.2, 1);
    {% elsif block.settings.transition_easing == 'bouncy' %}
      transition: transform {{ block.settings.transition_speed | divided_by: 1000.0 }}s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    {% else %}
      transition: transform {{ block.settings.transition_speed | divided_by: 1000.0 }}s ease-out;
    {% endif %}
    will-change: transform;
  }

  .ai-tiktok-carousel__track-{{ ai_gen_id }}.no-transition {
    transition: none !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-tiktok-carousel__track-{{ ai_gen_id }} {
      transition: transform 0.4s ease;
    }
  }

  .ai-tiktok-carousel__slide-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.video_width_desktop }}px;
    position: relative;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    background-color: #000;
    opacity: {{ block.settings.side_video_opacity | divided_by: 100.0 }};
    transform: scale({{ block.settings.side_video_scale | divided_by: 100.0 }});
    {% if block.settings.transition_easing == 'smooth' %}
      transition: opacity {{ block.settings.transition_speed | divided_by: 1000.0 }}s cubic-bezier(0.25, 0.46, 0.45, 0.94), 
                  transform {{ block.settings.transition_speed | divided_by: 1000.0 }}s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    {% elsif block.settings.transition_easing == 'snappy' %}
      transition: opacity {{ block.settings.transition_speed | divided_by: 1000.0 }}s cubic-bezier(0.4, 0, 0.2, 1), 
                  transform {{ block.settings.transition_speed | divided_by: 1000.0 }}s cubic-bezier(0.4, 0, 0.2, 1);
    {% elsif block.settings.transition_easing == 'bouncy' %}
      transition: opacity {{ block.settings.transition_speed | divided_by: 1000.0 }}s cubic-bezier(0.68, -0.55, 0.265, 1.55), 
                  transform {{ block.settings.transition_speed | divided_by: 1000.0 }}s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    {% else %}
      transition: opacity {{ block.settings.transition_speed | divided_by: 1000.0 }}s ease-out, 
                  transform {{ block.settings.transition_speed | divided_by: 1000.0 }}s ease-out;
    {% endif %}
    cursor: pointer;
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-tiktok-carousel__slide-{{ ai_gen_id }} {
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
  }

  .ai-tiktok-carousel__slide-{{ ai_gen_id }}.is-center {
    opacity: 1;
    transform: scale({{ block.settings.center_video_scale | divided_by: 100.0 }});
  }

  .ai-tiktok-carousel__video-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.video_height_desktop }}px;
    object-fit: cover;
    display: block;
    cursor: pointer;
  }

  .ai-tiktok-carousel__controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    right: 20px;
    display: flex;
    gap: 10px;
    z-index: 10;
    pointer-events: auto;
  }

  .ai-tiktok-carousel__control-btn-{{ ai_gen_id }} {
    width: {{ block.settings.control_button_size }}px;
    height: {{ block.settings.control_button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.control_bg_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), 
                transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    padding: 0;
    opacity: {{ block.settings.control_button_opacity | divided_by: 100.0 }};
  }

  .ai-tiktok-carousel__control-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.control_bg_hover_color }};
    transform: scale(1.1);
  }

  .ai-tiktok-carousel__control-btn-{{ ai_gen_id }}:active {
    transform: scale(0.95);
  }

  .ai-tiktok-carousel__control-btn-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.control_button_size }}px * 0.5);
    height: calc({{ block.settings.control_button_size }}px * 0.5);
    fill: {{ block.settings.control_icon_color }};
  }

  .ai-tiktok-carousel__nav-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-tiktok-carousel__nav-btn-{{ ai_gen_id }} {
    width: {{ block.settings.arrow_button_size }}px;
    height: {{ block.settings.arrow_button_size }}px;
    border-radius: {% if block.settings.arrow_style == 'square' %}8px{% elsif block.settings.arrow_style == 'rounded' %}12px{% else %}50%{% endif %};
    background-color: {{ block.settings.arrow_bg_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94), 
                transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    padding: 0;
    opacity: {{ block.settings.arrow_button_opacity | divided_by: 100.0 }};
  }

  .ai-tiktok-carousel__nav-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.arrow_bg_hover_color }};
    transform: scale(1.1);
  }

  .ai-tiktok-carousel__nav-btn-{{ ai_gen_id }}:active {
    transform: scale(0.95);
  }

  .ai-tiktok-carousel__nav-btn-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.arrow_button_size }}px * 0.5);
    height: calc({{ block.settings.arrow_button_size }}px * 0.5);
    fill: {{ block.settings.arrow_icon_color }};
  }

  .ai-tiktok-carousel__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.video_height_desktop }}px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-tiktok-carousel__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-tiktok-carousel__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-tiktok-carousel-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px 0 {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-tiktok-carousel__slide-{{ ai_gen_id }} {
      width: {{ block.settings.video_width_mobile }}px;
    }

    .ai-tiktok-carousel__video-{{ ai_gen_id }},
    .ai-tiktok-carousel__placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.video_height_mobile }}px;
    }

    .ai-tiktok-carousel__controls-{{ ai_gen_id }} {
      bottom: 15px;
      right: 15px;
      gap: 8px;
    }

    .ai-tiktok-carousel__control-btn-{{ ai_gen_id }} {
      width: calc({{ block.settings.control_button_size }}px * 0.85);
      height: calc({{ block.settings.control_button_size }}px * 0.85);
    }

    .ai-tiktok-carousel__nav-btn-{{ ai_gen_id }} {
      width: calc({{ block.settings.arrow_button_size }}px * 0.85);
      height: calc({{ block.settings.arrow_button_size }}px * 0.85);
    }
  }
{% endstyle %}

<tiktok-carousel-{{ ai_gen_id }}
  class="ai-tiktok-carousel-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-delay="{{ block.settings.autoplay_delay }}"
  data-start-muted="{{ block.settings.start_muted }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-tiktok-carousel__wrapper-{{ ai_gen_id }}">
    <div class="ai-tiktok-carousel__track-{{ ai_gen_id }}">
      {% liquid
        assign videos = ''
        for i in (1..10)
          assign video_key = 'video_' | append: i
          assign video = block.settings[video_key]
          if video != blank
            if videos == ''
              assign videos = video.id | append: ''
            else
              assign videos = videos | append: ',' | append: video.id
            endif
          endif
        endfor
        assign video_ids = videos | split: ','
        assign video_count = video_ids.size
      %}

      {% if video_count > 0 %}
        {% for i in (1..10) %}
          {% assign video_key = 'video_' | append: i %}
          {% assign video = block.settings[video_key] %}
          {% if video != blank %}
            <div class="ai-tiktok-carousel__slide-{{ ai_gen_id }}" data-slide-index="{{ forloop.index0 }}" data-original-index="{{ forloop.index0 }}">
              <video
                class="ai-tiktok-carousel__video-{{ ai_gen_id }}"
                src="{{ video.sources[1].url }}"
                playsinline
                loop
                {% if block.settings.start_muted %}muted{% endif %}
                preload="metadata"
                data-video-id="{{ forloop.index0 }}"
              ></video>
              <div class="ai-tiktok-carousel__controls-{{ ai_gen_id }}">
                <button
                  class="ai-tiktok-carousel__control-btn-{{ ai_gen_id }} ai-tiktok-carousel__play-btn-{{ ai_gen_id }}"
                  aria-label="Play or pause video"
                  data-action="play-pause"
                >
                  <svg class="ai-tiktok-carousel__play-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M8 5v14l11-7z"/>
                  </svg>
                  <svg class="ai-tiktok-carousel__pause-icon-{{ ai_gen_id }}" style="display: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
                  </svg>
                </button>
                <button
                  class="ai-tiktok-carousel__control-btn-{{ ai_gen_id }} ai-tiktok-carousel__mute-btn-{{ ai_gen_id }}"
                  aria-label="Mute or unmute video"
                  data-action="mute"
                >
                  <svg class="ai-tiktok-carousel__unmute-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
                  </svg>
                  <svg class="ai-tiktok-carousel__mute-icon-{{ ai_gen_id }}" style="display: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
                  </svg>
                </button>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="ai-tiktok-carousel__slide-{{ ai_gen_id }}">
          <div class="ai-tiktok-carousel__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-tiktok-carousel__empty-state-{{ ai_gen_id }}">
              Next, add videos from Shopify Files
            </div>
          </div>
        </div>
      {% endif %}
    </div>

    {% if video_count > 0 %}
      <div class="ai-tiktok-carousel__nav-{{ ai_gen_id }}">
        <button
          class="ai-tiktok-carousel__nav-btn-{{ ai_gen_id }}"
          aria-label="Previous video"
          data-nav="prev"
        >
          {% if block.settings.arrow_icon == 'chevron' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
            </svg>
          {% elsif block.settings.arrow_icon == 'arrow' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
            </svg>
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M11.67 3.87L9.9 2.1 0 12l9.9 9.9 1.77-1.77L3.54 12z"/>
            </svg>
          {% endif %}
        </button>
        <button
          class="ai-tiktok-carousel__nav-btn-{{ ai_gen_id }}"
          aria-label="Next video"
          data-nav="next"
        >
          {% if block.settings.arrow_icon == 'chevron' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
            </svg>
          {% elsif block.settings.arrow_icon == 'arrow' %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M4 11v2h12.17l-5.59 5.59L12 20l8-8-8-8-1.41 1.41L16.17 11H4z"/>
            </svg>
          {% else %}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M5.88 4.12L13.76 12l-7.88 7.88L8 22l10-10L8 2z"/>
            </svg>
          {% endif %}
        </button>
      </div>
    {% endif %}
  </div>
</tiktok-carousel-{{ ai_gen_id }}>

<script>
(function() {
  class TikTokCarousel{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
      this.currentIndex = 0;
      this.isTransitioning = false;
      this.debounceTimer = null;
      this.autoplayTimer = null;
      this.globalMuted = this.dataset.startMuted === 'true';
      this.slides = [];
      this.videos = [];
      this.originalSlides = [];
      this.cloneCount = 0;
      this.totalSlides = 0;
      this.touchStartX = 0;
      this.touchEndX = 0;
      this.rafId = null;
      this.videoStates = new Map();
    }

    connectedCallback() {
      this.track = this.querySelector('.ai-tiktok-carousel__track-{{ ai_gen_id }}');
      this.wrapper = this.querySelector('.ai-tiktok-carousel__wrapper-{{ ai_gen_id }}');
      this.originalSlides = Array.from(this.querySelectorAll('.ai-tiktok-carousel__slide-{{ ai_gen_id }}'));
      
      if (this.originalSlides.length === 0) return;

      this.totalSlides = this.originalSlides.length;
      
      if (this.totalSlides > 1) {
        this.setupInfiniteLoop();
      } else {
        this.slides = this.originalSlides;
        this.videos = this.slides.map(s => s.querySelector('video')).filter(v => v);
      }

      this.initializeVideoStates();
      this.setupEventListeners();
      this.updateMuteButtons();
      
      requestAnimationFrame(() => {
        this.goToSlide(this.cloneCount, false);
        this.updateCenterSlide(true);
      });
      
      if (this.dataset.autoplay === 'true') {
        this.startAutoplay();
      }

      this.setupKeyboardNavigation();
      this.setupTouchGestures();
    }

    initializeVideoStates() {
      this.videos.forEach((video, idx) => {
        if (video) {
          const originalIndex = this.slides[idx].getAttribute('data-original-index');
          if (!this.videoStates.has(originalIndex)) {
            this.videoStates.set(originalIndex, {
              currentTime: 0,
              isPlaying: false
            });
          }
        }
      });
    }

    setupInfiniteLoop() {
      this.cloneCount = Math.min(this.totalSlides, 3);
      
      for (let i = 0; i < this.cloneCount; i++) {
        const cloneStart = this.originalSlides[this.totalSlides - 1 - i].cloneNode(true);
        cloneStart.classList.add('clone-start');
        cloneStart.setAttribute('data-clone', 'start');
        const originalIndex = this.originalSlides[this.totalSlides - 1 - i].getAttribute('data-original-index');
        cloneStart.setAttribute('data-original-index', originalIndex);
        this.track.insertBefore(cloneStart, this.track.firstChild);
      }

      for (let i = 0; i < this.cloneCount; i++) {
        const cloneEnd = this.originalSlides[i].cloneNode(true);
        cloneEnd.classList.add('clone-end');
        cloneEnd.setAttribute('data-clone', 'end');
        const originalIndex = this.originalSlides[i].getAttribute('data-original-index');
        cloneEnd.setAttribute('data-original-index', originalIndex);
        this.track.appendChild(cloneEnd);
      }

      this.slides = Array.from(this.querySelectorAll('.ai-tiktok-carousel__slide-{{ ai_gen_id }}'));
      this.videos = this.slides.map(s => s.querySelector('video')).filter(v => v);
    }

    setupEventListeners() {
      this.slides.forEach((slide, index) => {
        const video = slide.querySelector('video');
        const playBtn = slide.querySelector('[data-action="play-pause"]');
        const muteBtn = slide.querySelector('[data-action="mute"]');

        if (video) {
          video.addEventListener('timeupdate', () => {
            const originalIndex = slide.getAttribute('data-original-index');
            const state = this.videoStates.get(originalIndex);
            if (state) {
              state.currentTime = video.currentTime;
            }
          });
        }

        slide.addEventListener('click', (e) => {
          if (e.target.closest('[data-action]')) {
            return;
          }
          this.handleSlideClick(index);
        });

        if (video) {
          video.addEventListener('click', (e) => {
            if (e.target.closest('[data-action]')) return;
            
            const centerIndex = this.currentIndex + this.cloneCount;
            if (index === centerIndex) {
              e.stopPropagation();
              this.togglePlayPause(index);
            }
          });
        }

        if (playBtn) {
          playBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            this.handlePlayPauseClick(index);
          });
        }

        if (muteBtn) {
          muteBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            this.handleMuteClick(index);
          });
        }
      });

      const prevBtn = this.querySelector('[data-nav="prev"]');
      const nextBtn = this.querySelector('[data-nav="next"]');

      if (prevBtn) {
        prevBtn.addEventListener('click', () => this.navigate('prev'));
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', () => this.navigate('next'));
      }

      this.track.addEventListener('transitionend', (e) => {
        if (e.target === this.track && e.propertyName === 'transform') {
          this.handleTransitionEnd();
        }
      });
    }

    setupTouchGestures() {
      this.track.addEventListener('touchstart', (e) => {
        this.touchStartX = e.changedTouches[0].screenX;
      }, { passive: true });

      this.track.addEventListener('touchend', (e) => {
        this.touchEndX = e.changedTouches[0].screenX;
        this.handleSwipe();
      }, { passive: true });
    }

    handleSwipe() {
      const swipeThreshold = 50;
      const diff = this.touchStartX - this.touchEndX;

      if (Math.abs(diff) > swipeThreshold) {
        if (diff > 0) {
          this.navigate('next');
        } else {
          this.navigate('prev');
        }
      }
    }

    handleSlideClick(index) {
      if (this.debounceTimer) return;

      this.debounceTimer = setTimeout(() => {
        this.debounceTimer = null;
      }, 300);

      const centerIndex = this.currentIndex + this.cloneCount;
      
      if (index !== centerIndex) {
        const diff = index - centerIndex;
        
        if (diff > 0) {
          for (let i = 0; i < diff; i++) {
            this.currentIndex++;
          }
        } else {
          for (let i = 0; i < Math.abs(diff); i++) {
            this.currentIndex--;
          }
        }
        
        this.goToSlide(this.currentIndex + this.cloneCount, true, true);
        
        if (this.dataset.autoplay === 'true') {
          this.stopAutoplay();
          this.startAutoplay();
        }
      }
    }

    handlePlayPauseClick(index) {
      if (this.debounceTimer) return;

      this.debounceTimer = setTimeout(() => {
        this.debounceTimer = null;
      }, 300);

      const centerIndex = this.currentIndex + this.cloneCount;
      
      if (index !== centerIndex) {
        const diff = index - centerIndex;
        
        if (diff > 0) {
          for (let i = 0; i < diff; i++) {
            this.currentIndex++;
          }
        } else {
          for (let i = 0; i < Math.abs(diff); i++) {
            this.currentIndex--;
          }
        }
        
        this.goToSlide(this.currentIndex + this.cloneCount, true, true);
        
        if (this.dataset.autoplay === 'true') {
          this.stopAutoplay();
          this.startAutoplay();
        }
      } else {
        this.togglePlayPause(index);
      }
    }

    handleMuteClick(index) {
      if (this.debounceTimer) return;

      this.debounceTimer = setTimeout(() => {
        this.debounceTimer = null;
      }, 300);

      const centerIndex = this.currentIndex + this.cloneCount;
      
      if (index !== centerIndex) {
        const diff = index - centerIndex;
        
        if (diff > 0) {
          for (let i = 0; i < diff; i++) {
            this.currentIndex++;
          }
        } else {
          for (let i = 0; i < Math.abs(diff); i++) {
            this.currentIndex--;
          }
        }
        
        this.goToSlide(this.currentIndex + this.cloneCount, true, true);
        
        if (this.dataset.autoplay === 'true') {
          this.stopAutoplay();
          this.startAutoplay();
        }
      } else {
        this.toggleGlobalMute();
      }
    }

    toggleGlobalMute() {
      this.globalMuted = !this.globalMuted;
      
      this.videos.forEach(video => {
        if (video) {
          video.muted = this.globalMuted;
        }
      });

      this.updateMuteButtons();
    }

    togglePlayPause(index) {
      const video = this.slides[index]?.querySelector('video');
      if (!video) return;

      const originalIndex = this.slides[index].getAttribute('data-original-index');
      const state = this.videoStates.get(originalIndex);

      if (video.paused) {
        this.pauseAllVideos();
        video.play().catch(() => {});
        if (state) state.isPlaying = true;
        this.updatePlayButton(this.slides[index], true);
      } else {
        video.pause();
        if (state) state.isPlaying = false;
        this.updatePlayButton(this.slides[index], false);
      }
    }

    pauseAllVideos() {
      this.videos.forEach((video, idx) => {
        if (video && !video.paused) {
          const originalIndex = this.slides[idx].getAttribute('data-original-index');
          const state = this.videoStates.get(originalIndex);
          
          video.pause();
          if (state) {
            state.isPlaying = false;
            state.currentTime = video.currentTime;
          }
          this.updatePlayButton(this.slides[idx], false);
        }
      });
    }

    syncVideoStates() {
      this.slides.forEach((slide, idx) => {
        const video = this.slides[idx]?.querySelector('video');
        if (!video) return;

        const originalIndex = slide.getAttribute('data-original-index');
        const state = this.videoStates.get(originalIndex);

        if (state && state.currentTime > 0) {
          video.currentTime = state.currentTime;
        }
      });
    }

    updatePlayButton(slide, isPlaying) {
      const playIcon = slide.querySelector('.ai-tiktok-carousel__play-icon-{{ ai_gen_id }}');
      const pauseIcon = slide.querySelector('.ai-tiktok-carousel__pause-icon-{{ ai_gen_id }}');
      
      if (playIcon && pauseIcon) {
        playIcon.style.display = isPlaying ? 'none' : 'block';
        pauseIcon.style.display = isPlaying ? 'block' : 'none';
      }
    }

    updateMuteButtons() {
      this.slides.forEach(slide => {
        const muteIcon = slide.querySelector('.ai-tiktok-carousel__mute-icon-{{ ai_gen_id }}');
        const unmuteIcon = slide.querySelector('.ai-tiktok-carousel__unmute-icon-{{ ai_gen_id }}');
        
        if (muteIcon && unmuteIcon) {
          muteIcon.style.display = this.globalMuted ? 'block' : 'none';
          unmuteIcon.style.display = this.globalMuted ? 'none' : 'block';
        }
      });
    }

    navigate(direction) {
      if (this.isTransitioning) return;

      this.stopAutoplay();
      
      if (direction === 'next') {
        this.currentIndex++;
      } else {
        this.currentIndex--;
      }

      this.goToSlide(this.currentIndex + this.cloneCount, true, true);

      if (this.dataset.autoplay === 'true') {
        this.startAutoplay();
      }
    }

    goToSlide(index, animate = true, shouldAutoplay = false) {
      if (this.isTransitioning && animate) return;

      if (this.rafId) {
        cancelAnimationFrame(this.rafId);
      }

      this.rafId = requestAnimationFrame(() => {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        const offset = (slideWidth + gap) * index;
        const centerOffset = (this.wrapper.offsetWidth - slideWidth) / 2;

        if (animate) {
          this.isTransitioning = true;
          this.track.classList.remove('no-transition');
        } else {
          this.track.classList.add('no-transition');
        }

        this.track.style.transform = `translateX(${centerOffset - offset}px)`;

        if (!animate) {
          this.syncVideoStates();
          this.updateCenterSlide(shouldAutoplay);
        }
      });
    }

    updateCenterSlide(shouldAutoplay = false) {
      const centerIndex = this.currentIndex + this.cloneCount;
      
      this.slides.forEach((slide, idx) => {
        if (idx === centerIndex) {
          slide.classList.add('is-center');
        } else {
          slide.classList.remove('is-center');
        }
      });

      if (shouldAutoplay) {
        this.pauseAllVideos();
        const video = this.slides[centerIndex]?.querySelector('video');
        if (video) {
          const originalIndex = this.slides[centerIndex].getAttribute('data-original-index');
          const state = this.videoStates.get(originalIndex);
          
          if (state && state.currentTime > 0) {
            video.currentTime = state.currentTime;
          }
          
          video.play().catch(() => {});
          if (state) state.isPlaying = true;
          this.updatePlayButton(this.slides[centerIndex], true);
        }
      }
    }

    handleTransitionEnd() {
      const shouldAutoplay = true;
      this.isTransitioning = false;

      if (this.totalSlides === 1) {
        this.updateCenterSlide(shouldAutoplay);
        return;
      }

      if (this.currentIndex >= this.totalSlides) {
        this.currentIndex = this.currentIndex % this.totalSlides;
        
        requestAnimationFrame(() => {
          this.track.classList.add('no-transition');
          
          const slideWidth = this.slides[0].offsetWidth;
          const gap = parseInt(getComputedStyle(this.track).gap) || 0;
          const offset = (slideWidth + gap) * (this.currentIndex + this.cloneCount);
          const centerOffset = (this.wrapper.offsetWidth - slideWidth) / 2;
          this.track.style.transform = `translateX(${centerOffset - offset}px)`;
          
          requestAnimationFrame(() => {
            this.syncVideoStates();
            this.updateCenterSlide(shouldAutoplay);
            requestAnimationFrame(() => {
              this.track.classList.remove('no-transition');
            });
          });
        });
      } else if (this.currentIndex < 0) {
        this.currentIndex = this.totalSlides + (this.currentIndex % this.totalSlides);
        
        requestAnimationFrame(() => {
          this.track.classList.add('no-transition');
          
          const slideWidth = this.slides[0].offsetWidth;
          const gap = parseInt(getComputedStyle(this.track).gap) || 0;
          const offset = (slideWidth + gap) * (this.currentIndex + this.cloneCount);
          const centerOffset = (this.wrapper.offsetWidth - slideWidth) / 2;
          this.track.style.transform = `translateX(${centerOffset - offset}px)`;
          
          requestAnimationFrame(() => {
            this.syncVideoStates();
            this.updateCenterSlide(shouldAutoplay);
            requestAnimationFrame(() => {
              this.track.classList.remove('no-transition');
            });
          });
        });
      } else {
        this.updateCenterSlide(shouldAutoplay);
      }
    }

    startAutoplay() {
      this.stopAutoplay();
      const delay = parseInt(this.dataset.autoplayDelay) * 1000;
      
      this.autoplayTimer = setInterval(() => {
        this.navigate('next');
      }, delay);
    }

    stopAutoplay() {
      if (this.autoplayTimer) {
        clearInterval(this.autoplayTimer);
        this.autoplayTimer = null;
      }
    }

    setupKeyboardNavigation() {
      this.setAttribute('tabindex', '0');
      
      this.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          this.navigate('prev');
        } else if (e.key === 'ArrowRight') {
          e.preventDefault();
          this.navigate('next');
        } else if (e.key === ' ') {
          e.preventDefault();
          const centerIndex = this.currentIndex + this.cloneCount;
          this.togglePlayPause(centerIndex);
        }
      });
    }

    disconnectedCallback() {
      this.stopAutoplay();
      if (this.rafId) {
        cancelAnimationFrame(this.rafId);
      }
    }
  }

  customElements.define('tiktok-carousel-{{ ai_gen_id }}', TikTokCarousel{{ ai_gen_id }});
})();
</script>

