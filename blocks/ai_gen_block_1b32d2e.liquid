{% doc %}
  @prompt
    tik tok vids corrousel i will embed links, make the work tikok clickable directing to link

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-tiktok-carousel-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-tiktok-carousel__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: 30px;
  }

  .ai-tiktok-carousel__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 10px;font-weight: 600;
  }

  .ai-tiktok-carousel__title-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .ai-tiktok-carousel__title-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-tiktok-carousel__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;opacity: 0.8;
  }

  .ai-tiktok-carousel__container-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-tiktok-carousel__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.video_spacing }}px;
    transition: transform 0.3s ease;
    will-change: transform;
  }

  .ai-tiktok-carousel__slide-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.video_width }}px;
    height: {{ block.settings.video_height }}px;
    position: relative;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    background-color: #f0f0f0;
  }

  .ai-tiktok-carousel__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    border: none;
    border-radius: {{ block.settings.video_border_radius }}px;}

  .ai-tiktok-carousel__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.video_border_radius }}px;position: relative;
  }

  .ai-tiktok-carousel__placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.5;
    margin-bottom: 10px;
  }

  .ai-tiktok-carousel__placeholder-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: #666;
    text-align: center;
    padding: 0 20px;
  }

  .ai-tiktok-carousel__controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-tiktok-carousel__nav-button-{{ ai_gen_id }} {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: none;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;opacity: 0.7;
  }

  .ai-tiktok-carousel__nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    opacity: 1;
    transform: scale(1.05);
  }

  .ai-tiktok-carousel__nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: none;
  }

  .ai-tiktok-carousel__nav-button-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-tiktok-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-tiktok-carousel__dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background-color: {{ block.settings.button_color }};
    opacity: 0.3;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-tiktok-carousel__dot-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1.2);
  }

  .ai-tiktok-carousel__empty-state-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #666;
  }

  .ai-tiktok-carousel__empty-state-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
    margin-bottom: 20px;
  }

  @media screen and (max-width: 768px) {
    .ai-tiktok-carousel__slide-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.video_width | times: 0.8 }}px;
      height: {{ block.settings.video_height | times: 0.8 }}px;
    }

    .ai-tiktok-carousel__controls-{{ ai_gen_id }} {
      margin-top: 20px;
    }

    .ai-tiktok-carousel__nav-button-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-tiktok-carousel__nav-button-{{ ai_gen_id }} svg {
      width: 16px;
      height: 16px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-tiktok-carousel__slide-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.video_width | times: 0.6 }}px;
      height: {{ block.settings.video_height | times: 0.6 }}px;
    }
  }
{% endstyle %}<tiktok-carousel-{{ ai_gen_id }}
  class="ai-tiktok-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.title != blank or block.settings.subtitle != blank %}
    <div class="ai-tiktok-carousel__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-tiktok-carousel__title-{{ ai_gen_id }}">
          {% if block.settings.tiktok_profile_link != blank %}
            <a href="{{ block.settings.tiktok_profile_link }}" class="ai-tiktok-carousel__title-link-{{ ai_gen_id }}" target="_blank" rel="noopener noreferrer">
              {{ block.settings.title }}
            </a>
          {% else %}
            {{ block.settings.title }}
          {% endif %}
        </h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-tiktok-carousel__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>
  {% endif %}

  {% assign has_videos = false %}
  {% for i in (1..5) %}
    {% assign video_url_key = 'video_url_' | append: i %}
    {% if block.settings[video_url_key] != blank %}
      {% assign has_videos = true %}
      {% break %}
    {% endif %}
  {% endfor %}

  {% if has_videos %}
    <div class="ai-tiktok-carousel__container-{{ ai_gen_id }}">
      <div class="ai-tiktok-carousel__track-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% assign video_url_key = 'video_url_' | append: i %}
          {% assign video_url = block.settings[video_url_key] %}
          {% if video_url != blank %}
            <div class="ai-tiktok-carousel__slide-{{ ai_gen_id }}">
              <iframe
                class="ai-tiktok-carousel__video-{{ ai_gen_id }}"
                src="{{ video_url }}"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div><div class="ai-tiktok-carousel__controls-{{ ai_gen_id }}">
      <button
        class="ai-tiktok-carousel__nav-button-{{ ai_gen_id }} ai-tiktok-carousel__prev-{{ ai_gen_id }}"
        aria-label="Previous video"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15,18 9,12 15,6"></polyline>
        </svg>
      </button>

      <div class="ai-tiktok-carousel__dots-{{ ai_gen_id }}"></div>

      <button
        class="ai-tiktok-carousel__nav-button-{{ ai_gen_id }} ai-tiktok-carousel__next-{{ ai_gen_id }}"
        aria-label="Next video"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9,18 15,12 9,6"></polyline>
        </svg>
      </button>
    </div>
  {% else %}
    <div class="ai-tiktok-carousel__empty-state-{{ ai_gen_id }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polygon points="23 7 16 12 23 17 23 7"></polygon>
        <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
      </svg>
      <h3>Add TikTok Videos</h3>
      <p>Add your TikTok embed links in the block settings to get started</p>
    </div>
  {% endif %}
</tiktok-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class TikTokCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slidesPerView = {{ block.settings.slides_per_view }};
        this.autoplayEnabled = {{ block.settings.enable_autoplay }};
        this.autoplayDelay = {{ block.settings.autoplay_delay }} * 1000;
        this.autoplayTimer = null;}

      connectedCallback() {
        this.track = this.querySelector('.ai-tiktok-carousel__track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-tiktok-carousel__slide-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-tiktok-carousel__prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-tiktok-carousel__next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-tiktok-carousel__dots-{{ ai_gen_id }}');

        if (!this.track || this.slides.length === 0) return;

        this.totalSlides = this.slides.length;
        this.maxSlide = Math.max(0, this.totalSlides - this.slidesPerView);

        this.createDots();
        this.setupEventListeners();
        this.updateCarousel();
        this.updateControls();

        if (this.autoplayEnabled && this.totalSlides > this.slidesPerView) {
          this.startAutoplay();
        }
      }

      createDots() {
        if (!this.dotsContainer) return;

        const totalDots = this.maxSlide + 1;
        for (let i = 0; i < totalDots; i++) {
          const dot = document.createElement('button');
          dot.className = `ai-tiktok-carousel__dot-{{ ai_gen_id }}`;
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          if (this.autoplayEnabled && this.totalSlides > this.slidesPerView) {
            this.startAutoplay();
          }
        });

        window.addEventListener('resize', () => this.updateCarousel());
      }

      updateCarousel() {
        if (!this.track) return;

        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.video_spacing }};
        const translateX = -(this.currentSlide * (slideWidth + gap));

        this.track.style.transform = `translateX(${translateX}px)`;
        this.updateDots();
      }

      updateDots() {
        const dots = this.querySelectorAll('.ai-tiktok-carousel__dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentSlide);
        });
      }

      updateControls() {
        if (this.prevButton) {
          this.prevButton.disabled = this.currentSlide === 0;
        }

        if (this.nextButton) {
          this.nextButton.disabled = this.currentSlide >= this.maxSlide;
        }
      }

      goToSlide(slideIndex) {
        this.currentSlide = Math.max(0, Math.min(slideIndex, this.maxSlide));
        this.updateCarousel();
        this.updateControls();
        this.resetAutoplay();
      }

      nextSlide() {
        if (this.currentSlide < this.maxSlide) {
          this.goToSlide(this.currentSlide + 1);
        } else if (this.autoplayEnabled) {
          this.goToSlide(0);
        }
      }

      previousSlide() {
        if (this.currentSlide > 0) {
          this.goToSlide(this.currentSlide - 1);
        }
      }

      startAutoplay() {
        if (!this.autoplayEnabled || this.totalSlides <= this.slidesPerView) return;

        this.stopAutoplay();
        this.autoplayTimer = setInterval(() => {
          this.nextSlide();
        }, this.autoplayDelay);
      }

      stopAutoplay() {
        if (this.autoplayTimer) {
          clearInterval(this.autoplayTimer);
          this.autoplayTimer = null;
        }
      }

      resetAutoplay() {
        if (this.autoplayEnabled) {
          this.stopAutoplay();
          this.startAutoplay();
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('tiktok-carousel-{{ ai_gen_id }}', TikTokCarousel{{ ai_gen_id }});
  })();
</script>

