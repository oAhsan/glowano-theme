      "label": "Title size",
      "default": 18
    },
    {
      "type": "range",
      "id": "card_price_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Price size",
      "default": 16
    },
    {
      "type": "color",
      "id": "card_button_color",
      "label": "Button color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
