      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Vertical position",
      "default": 40
    },
    {
      "type": "product",
      "id": "hotspot_1_product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Hotspot 2"
    },
    {
      "type": "checkbox",
      "id": "hotspot_2_enabled",
      "label": "Enable hotspot 2",
      "default": true
    },
    {
      "type": "range",
      "id": "hotspot_2_x",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Horizontal position",
      "default": 70
    },
    {
      "type": "range",
      "id": "hotspot_2_y",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Vertical position",
      "default": 60
    },
    {
      "type": "product",
      "id": "hotspot_2_product",
      "label": "Product"
    },
    {
      "type": "header",
