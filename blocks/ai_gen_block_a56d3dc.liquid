{% doc %}
  @prompt
    Create a Testimonial carousel section for my Shopify store homepage.
    Requirements:
    
    Display one testimonial at a time.
    
    Show the person’s name below the testimonial.
    
    Below the name, include navigation dots representing each testimonial.
    
    Clicking a dot should skip to the corresponding testimonial.
    
    Include smooth sliding or fading transitions between testimonials.
    
    Section should be minimal, clean, and modern, fitting my Glowano homepage style (black/gold theme).
    
    Section must be responsive on desktop and mobile.
    
    Use Shopify section/block system so I can add/edit testimonials easily in the editor, fix background color it should cover whole space and the design should also be mobile responsive as well and make the dots hollow from inside, and make everything highly customizable, allow all option in all text boxes all features like heading bold italic like, make the background color change from pallete and there is too much extra space bewtween quote and dots reduce it and a bit of padding below dots, reduce the distance between text and dots, and make the bg work, reduce the distance between testimonials and dots or just give control to place them higher, i want dots even higher, give extra controls for dots to place higher, allow me to place the dots even higher dont take the testimonial as reference for distance, make sure these dots are clickable
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-testimonial-carousel-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background: {{ block.settings.color_scheme.settings.background_gradient }};
    background-color: {{ block.settings.color_scheme.settings.background }};
    width: 100%;
  }

  .ai-testimonial-carousel__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-testimonial-carousel__heading-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-weight: {{ block.settings.heading_weight }};
    font-style: {% if block.settings.heading_italic %}italic{% else %}normal{% endif %};
    text-transform: {{ block.settings.heading_transform }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
  }

  .ai-testimonial-carousel__track-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-testimonial-carousel__slides-{{ ai_gen_id }} {
    display: flex;
    transition: transform {{ block.settings.transition_speed }}ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-testimonial-carousel__slide-{{ ai_gen_id }} {
    min-width: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_speed }}ms ease;
  }

  .ai-testimonial-carousel__slide-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-testimonial-carousel__content-{{ ai_gen_id }} {
    text-align: {{ block.settings.content_alignment }};
    padding: 0 {{ block.settings.content_padding }}px;
  }

  .ai-testimonial-carousel__quote-{{ ai_gen_id }} {
    font-size: {{ block.settings.quote_size }}px;
    line-height: {{ block.settings.quote_line_height }};
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.quote_spacing }}px;
    font-style: {% if block.settings.quote_italic %}italic{% else %}normal{% endif %};
    font-weight: {{ block.settings.quote_weight }};
    letter-spacing: {{ block.settings.quote_letter_spacing }}px;
  }

  .ai-testimonial-carousel__quote-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-testimonial-carousel__author-{{ ai_gen_id }} {
    font-size: {{ block.settings.author_size }}px;
    color: {{ block.settings.author_color }};
    font-weight: {{ block.settings.author_weight }};
    margin: 0;
    font-style: {% if block.settings.author_italic %}italic{% else %}normal{% endif %};
    text-transform: {{ block.settings.author_transform }};
    letter-spacing: {{ block.settings.author_letter_spacing }}px;
  }

  .ai-testimonial-carousel__author-{{ ai_gen_id }} p {
    margin: 0;
  }

  .ai-testimonial-carousel__dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: {{ block.settings.dots_gap }}px;
    margin-top: {{ block.settings.dots_spacing }}px;
    padding-bottom: {{ block.settings.dots_padding_bottom }}px;
    position: relative;
    z-index: 10;
  }

  .ai-testimonial-carousel__dot-{{ ai_gen_id }} {
    width: {{ block.settings.dot_size }}px;
    height: {{ block.settings.dot_size }}px;
    border-radius: 50%;
    background-color: transparent;
    border: {{ block.settings.dot_border_width }}px solid {{ block.settings.dot_inactive_color }};
    cursor: pointer;
    transition: all {{ block.settings.dot_transition_speed }}ms ease;
    padding: 0;
    position: relative;
    z-index: 10;
    pointer-events: auto;
  }

  .ai-testimonial-carousel__dot-{{ ai_gen_id }}:hover {
    transform: scale({{ block.settings.dot_hover_scale }});
    border-color: {{ block.settings.dot_hover_color }};
  }

  .ai-testimonial-carousel__dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    border-color: {{ block.settings.dot_active_color }};
    transform: scale({{ block.settings.dot_active_scale }});
  }

  @media screen and (max-width: 749px) {
    .ai-testimonial-carousel-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px 0 {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-testimonial-carousel__container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.mobile_padding }}px;
    }

    .ai-testimonial-carousel__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.heading_spacing_mobile }}px;
    }

    .ai-testimonial-carousel__quote-{{ ai_gen_id }} {
      font-size: {{ block.settings.quote_size_mobile }}px;
      margin-bottom: {{ block.settings.quote_spacing_mobile }}px;
    }

    .ai-testimonial-carousel__author-{{ ai_gen_id }} {
      font-size: {{ block.settings.author_size_mobile }}px;
    }

    .ai-testimonial-carousel__content-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.content_padding_mobile }}px;
    }

    .ai-testimonial-carousel__dots-{{ ai_gen_id }} {
      margin-top: {{ block.settings.dots_spacing_mobile }}px;
      gap: {{ block.settings.dots_gap_mobile }}px;
      padding-bottom: {{ block.settings.dots_padding_bottom_mobile }}px;
    }

    .ai-testimonial-carousel__dot-{{ ai_gen_id }} {
      width: {{ block.settings.dot_size_mobile }}px;
      height: {{ block.settings.dot_size_mobile }}px;
    }
  }
{% endstyle %}

<testimonial-carousel-{{ ai_gen_id }}
  class="ai-testimonial-carousel-{{ ai_gen_id }}"
  data-autoplay="{{ block.settings.autoplay }}"
  data-autoplay-speed="{{ block.settings.autoplay_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-testimonial-carousel__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-testimonial-carousel__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </div>
    {% endif %}

    <div class="ai-testimonial-carousel__track-{{ ai_gen_id }}">
      <div class="ai-testimonial-carousel__slides-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign quote_key = 'testimonial_' | append: i | append: '_quote'
            assign author_key = 'testimonial_' | append: i | append: '_author'
            assign quote = block.settings[quote_key]
            assign author = block.settings[author_key]
          %}

          {% if quote != blank %}
            <div
              class="ai-testimonial-carousel__slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
              data-slide-index="{{ forloop.index0 }}"
            >
              <div class="ai-testimonial-carousel__content-{{ ai_gen_id }}">
                <div class="ai-testimonial-carousel__quote-{{ ai_gen_id }}">
                  {{ quote }}
                </div>
                {% if author != blank %}
                  <div class="ai-testimonial-carousel__author-{{ ai_gen_id }}">
                    {{ author }}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ai-testimonial-carousel__dots-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign quote_key = 'testimonial_' | append: i | append: '_quote'
          assign quote = block.settings[quote_key]
        %}

        {% if quote != blank %}
          <button
            type="button"
            class="ai-testimonial-carousel__dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
            data-dot-index="{{ forloop.index0 }}"
            aria-label="Go to testimonial {{ forloop.index }}"
            tabindex="0"
          ></button>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</testimonial-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class TestimonialCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = this.querySelectorAll('.ai-testimonial-carousel__slide-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-testimonial-carousel__dot-{{ ai_gen_id }}');
        this.slidesContainer = this.querySelector('.ai-testimonial-carousel__slides-{{ ai_gen_id }}');
        this.autoplay = this.dataset.autoplay === 'true';
        this.autoplaySpeed = parseInt(this.dataset.autoplaySpeed) || 5000;

        if (this.slides.length === 0) return;

        this.setupEventListeners();

        if (this.autoplay && this.slides.length > 1) {
          this.startAutoplay();
        }
      }

      setupEventListeners() {
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            this.goToSlide(index);
            if (this.autoplay) {
              this.resetAutoplay();
            }
          });

          dot.addEventListener('keydown', (e) => {
            if (e.key === 'Enter' || e.key === ' ') {
              e.preventDefault();
              this.goToSlide(index);
              if (this.autoplay) {
                this.resetAutoplay();
              }
            }
          });
        });
      }

      goToSlide(index) {
        if (index === this.currentIndex) return;

        this.slides[this.currentIndex].classList.remove('active');
        this.dots[this.currentIndex].classList.remove('active');

        this.currentIndex = index;

        this.slides[this.currentIndex].classList.add('active');
        this.dots[this.currentIndex].classList.add('active');

        this.slidesContainer.style.transform = `translateX(-${this.currentIndex * 100}%)`;
      }

      nextSlide() {
        const nextIndex = (this.currentIndex + 1) % this.slides.length;
        this.goToSlide(nextIndex);
      }

      startAutoplay() {
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, this.autoplaySpeed);
      }

      resetAutoplay() {
        clearInterval(this.autoplayInterval);
        this.startAutoplay();
      }

      disconnectedCallback() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
        }
      }
    }

    customElements.define('testimonial-carousel-{{ ai_gen_id }}', TestimonialCarousel{{ ai_gen_id }});
  })();
</script>

