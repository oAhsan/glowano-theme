{% doc %}
  @prompt
    Create a fully responsive luxury section called “Glowano Interactive Banner.” The section should allow me to upload one banner image for mobile. On top of the banner, place exactly two visible glowing hotspots that pulse with a soft golden light. Each hotspot should always stay clickable, and when the user taps or hovers, a black tooltip box with a thin gold border should appear, showing editable text from the theme editor. The hotspots should feel alive — they softly expand and contract with a smooth animation, like breathing. To make it premium, add a faint golden ripple effect when a hotspot is clicked, fading out like water. The design must look modern and luxurious, perfectly fitting a beauty brand. Everything should be mobile-friendly and feel immersive without slowing down the site.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-glowano-banner-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-glowano-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-glowano-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-glowano-placeholder-{{ ai_gen_id }} {
    background-color: #f8f8f8;
    width: 100%;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-glowano-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-glowano-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-glowano-hotspot-{{ ai_gen_id }} {
    position: absolute;
    top: var(--ai-glowano-y-{{ ai_gen_id }});
    left: var(--ai-glowano-x-{{ ai_gen_id }});
    transform: translate(-50%, -50%);
    z-index: 10;
  }

  .ai-glowano-hotspot-button-{{ ai_gen_id }} {
    width: {{ block.settings.hotspot_size }}px;
    height: {{ block.settings.hotspot_size }}px;
    border-radius: 50%;
    background: radial-gradient(circle, #ffd700 0%, #ffb347 100%);
    border: none;
    cursor: pointer;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: ai-glowano-pulse-{{ ai_gen_id }} 2s ease-in-out infinite;
    box-shadow: 0 0 20px rgba(255, 215, 0, 0.6);
  }

  .ai-glowano-hotspot-button-{{ ai_gen_id }}:before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background: rgba(255, 215, 0, 0.3);
    transform: translate(-50%, -50%) scale(1);
    animation: ai-glowano-glow-{{ ai_gen_id }} 2s ease-in-out infinite;
  }

  .ai-glowano-hotspot-button-{{ ai_gen_id }}:after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #fff;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 4px rgba(0, 0, 0, 0.2);
  }

  .ai-glowano-ripple-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    width: 0;
    height: 0;
    border-radius: 50%;
    background: rgba(255, 215, 0, 0.4);
    transform: translate(-50%, -50%);
    pointer-events: none;
    opacity: 0;
  }

  .ai-glowano-ripple-{{ ai_gen_id }}.active {
    animation: ai-glowano-ripple-effect-{{ ai_gen_id }} 0.8s ease-out forwards;
  }

  .ai-glowano-tooltip-{{ ai_gen_id }} {
    position: absolute;
    background: #000;
    color: #fff;
    padding: 12px 16px;
    border-radius: 6px;
    border: 1px solid #ffd700;
    font-size: 14px;
    white-space: nowrap;
    max-width: 200px;
    white-space: normal;
    line-height: 1.4;
    z-index: 20;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }

  .ai-glowano-tooltip-{{ ai_gen_id }}:before {
    content: '';
    position: absolute;
    width: 0;
    height: 0;
    border-style: solid;
  }

  .ai-glowano-tooltip-{{ ai_gen_id }}--top {
    bottom: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(10px);
  }

  .ai-glowano-tooltip-{{ ai_gen_id }}--top:before {
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-width: 6px 6px 0 6px;
    border-color: #ffd700 transparent transparent transparent;
  }

  .ai-glowano-tooltip-{{ ai_gen_id }}--bottom {
    top: calc(100% + 10px);
    left: 50%;
    transform: translateX(-50%) translateY(-10px);
  }

  .ai-glowano-tooltip-{{ ai_gen_id }}--bottom:before {
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-width: 0 6px 6px 6px;
    border-color: transparent transparent #ffd700 transparent;
  }

  .ai-glowano-tooltip-{{ ai_gen_id }}.show {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  @keyframes ai-glowano-pulse-{{ ai_gen_id }} {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
  }

  @keyframes ai-glowano-glow-{{ ai_gen_id }} {
    0%, 100% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.3;
    }
    50% {
      transform: translate(-50%, -50%) scale(1.5);
      opacity: 0.1;
    }
  }

  @keyframes ai-glowano-ripple-effect-{{ ai_gen_id }} {
    0% {
      width: 0;
      height: 0;
      opacity: 0.6;
    }
    100% {
      width: 100px;
      height: 100px;
      opacity: 0;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-glowano-hotspot-button-{{ ai_gen_id }} {
      width: {{ block.settings.hotspot_size | times: 0.8 }}px;
      height: {{ block.settings.hotspot_size | times: 0.8 }}px;
    }

    .ai-glowano-tooltip-{{ ai_gen_id }} {
      max-width: 150px;
      font-size: 12px;
      padding: 10px 12px;
    }
  }
{% endstyle %}

<glowano-banner-{{ ai_gen_id }}
  class="ai-glowano-banner-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-glowano-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.banner_image %}
      <img
        src="{{ block.settings.banner_image | image_url: width: 2000 }}"
        alt="{{ block.settings.banner_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.banner_image.width }}"
        height="{{ block.settings.banner_image.height }}"
        class="ai-glowano-image-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-glowano-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-glowano-empty-state-{{ ai_gen_id }}">
          Add a banner image to get started
        </div>
      </div>
    {% endif %}

    {% for i in (1..2) %}
      {% liquid
        assign hotspot_x_key = 'hotspot_' | append: i | append: '_x'
        assign hotspot_y_key = 'hotspot_' | append: i | append: '_y'
        assign tooltip_text_key = 'hotspot_' | append: i | append: '_text'
        assign tooltip_position_key = 'hotspot_' | append: i | append: '_position'

        assign hotspot_x = block.settings[hotspot_x_key]
        assign hotspot_y = block.settings[hotspot_y_key]
        assign tooltip_text = block.settings[tooltip_text_key]
        assign tooltip_position = block.settings[tooltip_position_key]
      %}

      <div
        class="ai-glowano-hotspot-{{ ai_gen_id }}"
        style="
          --ai-glowano-x-{{ ai_gen_id }}: {{ hotspot_x }}%;
          --ai-glowano-y-{{ ai_gen_id }}: {{ hotspot_y }}%;
        "
        data-hotspot="{{ i }}"
      >
        <button
          class="ai-glowano-hotspot-button-{{ ai_gen_id }}"
          aria-label="View details"
          data-tooltip-text="{{ tooltip_text | escape }}"
          data-tooltip-position="{{ tooltip_position }}">
          <div class="ai-glowano-ripple-{{ ai_gen_id }}"></div>
        </button>

        {% if tooltip_text != blank %}
          <div class="ai-glowano-tooltip-{{ ai_gen_id }} ai-glowano-tooltip-{{ ai_gen_id }}--{{ tooltip_position }}">
            {{ tooltip_text }}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</glowano-banner-{{ ai_gen_id }}>

<script>
  (function() {
    class GlowanoBanner{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.activeTooltip = null;
      }

      connectedCallback() {
        this.hotspots = this.querySelectorAll('.ai-glowano-hotspot-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.hotspots.forEach((hotspot) => {
          const button = hotspot.querySelector('.ai-glowano-hotspot-button-{{ ai_gen_id }}');
          const tooltip = hotspot.querySelector('.ai-glowano-tooltip-{{ ai_gen_id }}');
          const ripple = button.querySelector('.ai-glowano-ripple-{{ ai_gen_id }}');

          if (tooltip) {
            button.addEventListener('mouseenter', () => {
              this.showTooltip(tooltip);
            });

            button.addEventListener('mouseleave', () => {
              this.hideTooltip(tooltip);
            });

            button.addEventListener('click', (e) => {
              e.preventDefault();
              this.createRipple(ripple);
              
              if (window.innerWidth <= 749) {
                if (this.activeTooltip === tooltip) {
                  this.hideTooltip(tooltip);this.activeTooltip = null;
                } else {
                  this.hideAllTooltips();
                  this.showTooltip(tooltip);
                  this.activeTooltip = tooltip;
                }
              }
            });
          }
        });document.addEventListener('click', (e) => {
          if (!e.target.closest('.ai-glowano-hotspot-{{ ai_gen_id }}')) {
            this.hideAllTooltips();
            this.activeTooltip = null;
          }
        });
      }

      showTooltip(tooltip) {
        tooltip.classList.add('show');}

      hideTooltip(tooltip) {
        tooltip.classList.remove('show');
      }

      hideAllTooltips() {
        this.querySelectorAll('.ai-glowano-tooltip-{{ ai_gen_id }}').forEach(tooltip => {
          tooltip.classList.remove('show');
        });
      }

      createRipple(ripple) {
        ripple.classList.remove('active');
        setTimeout(() => {
          ripple.classList.add('active');
        }, 10);
      }
    }

    customElements.define('glowano-banner-{{ ai_gen_id }}', GlowanoBanner{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Glowano banner",
  "settings": [
    {
      "type": "header",
      "content": "Banner image"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner image"
    },
    {
      "type": "range",
      "id": "hotspot_size",
      "min": 20,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Hotspot size",
      "default": 30
    },
    {
      "type": "header",
      "content": "Hotspot 1"
    },
    {
      "type": "range",
      "id": "hotspot_1_x",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Horizontal position",
      "default": 30
    },
    {
      "type": "range",
      "id": "hotspot_1_y",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Vertical position",
      "default": 40
    },
    {
      "type": "text",
      "id": "hotspot_1_text",
      "label": "Tooltip text",
      "default": "Discover our premium collection"
    },
    {
      "type": "select",
      "id": "hotspot_1_position",
      "label": "Tooltip position",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "top"
    },
    {
      "type": "header",
      "content": "Hotspot 2"
    },
    {
      "type": "range",
      "id": "hotspot_2_x",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Horizontal position",
      "default": 70
    },
    {
      "type": "range",
      "id": "hotspot_2_y",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Vertical position",
      "default": 60
    },
    {
      "type": "text",
      "id": "hotspot_2_text",
      "label": "Tooltip text",
      "default": "Luxury skincare essentials"
    },
    {
      "type": "select",
      "id": "hotspot_2_position",
      "label": "Tooltip position",
      "options": [
        {
          "value": "top",
          "label": "Top"
        },
        {
          "value": "bottom",
          "label": "Bottom"
        }
      ],
      "default": "bottom"
    }
  ],
  "presets": [
    {
      "name": "Glowano banner"
    }
  ],
  "tag": null
}
{% endschema %}