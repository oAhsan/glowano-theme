{% doc %}
  @prompt
    Design a product highlight section with one featured product at the center, subtle glowing borders, and text blocks that fade in as you scroll.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-highlight-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-product-highlight-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 40px;
    align-items: center;
    min-height: 500px;
  }

  .ai-product-highlight-text-block-{{ ai_gen_id }} {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ai-product-highlight-text-block-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .ai-product-highlight-text-block-{{ ai_gen_id }}:nth-child(1) {
    transition-delay: 0.2s;
  }

  .ai-product-highlight-text-block-{{ ai_gen_id }}:nth-child(3) {
    transition-delay: 0.4s;
  }

  .ai-product-highlight-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;}

  .ai-product-highlight-text-{{ ai_gen_id }} h3 {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 16px 0;
    font-weight: 600;
  }

  .ai-product-highlight-product-{{ ai_gen_id }} {
    position: relative;
    text-align: center;
    opacity: 0;
    transform: scale(0.9);
    transition: opacity 1s ease, transform 1s ease;
  }

  .ai-product-highlight-product-{{ ai_gen_id }}.visible {
    opacity: 1;
    transform: scale(1);
  }

  .ai-product-highlight-product-card-{{ ai_gen_id }} {
    position: relative;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.border_radius }}px;
    padding: 30px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    border: 2px solid transparent;
    background-clip: padding-box;}

  .ai-product-highlight-product-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(45deg, {{ block.settings.glow_color_1 }}, {{ block.settings.glow_color_2 }}, {{ block.settings.glow_color_1 }});
    border-radius: {{ block.settings.border_radius }}px;
    z-index: -1;
    opacity: {{ block.settings.glow_opacity | divided_by: 100.0 }};
    animation: ai-product-highlight-glow-{{ ai_gen_id }} 3s ease-in-out infinite alternate;
  }

  @keyframes ai-product-highlight-glow-{{ ai_gen_id }} {
    0% {
      filter: blur({{ block.settings.glow_blur }}px) brightness(1);
    }
    100% {
      filter: blur({{ block.settings.glow_blur }}px) brightness(1.2);
    }
  }

  .ai-product-highlight-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 20px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-product-highlight-image-{{ ai_gen_id }} {
    width: 100%;
    height: 300px;
    object-fit: cover;
    display: block;
  }

  .ai-product-highlight-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 300px;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-product-highlight-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-highlight-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
    font-size: 12px;
    color: #666;
    text-align: center;
  }

  .ai-product-highlight-product-title-{{ ai_gen_id }} {
    color: {{ block.settings.product_title_color }};
    font-size: {{ block.settings.product_title_size }}px;
    margin: 0 0 12px 0;
    font-weight: 600;
  }

  .ai-product-highlight-product-price-{{ ai_gen_id }} {
    color: {{ block.settings.product_price_color }};
    font-size: {{ block.settings.product_price_size }}px;
    margin-bottom: 20px;
    font-weight: 500;
  }

  .ai-product-highlight-product-description-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 14px;
    line-height: 1.5;
    margin-bottom: 24px;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-product-highlight-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-weight: 500;
    transition: background-color 0.3s ease, transform 0.2s ease;
  }

  .ai-product-highlight-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    transform: translateY(-2px);
  }

  .ai-product-highlight-empty-product-{{ ai_gen_id }} {
    color: #999;
    font-style: italic;
    padding: 40px 20px;
  }

  @media screen and (max-width: 768px) {
    .ai-product-highlight-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
      text-align: center;
    }

    .ai-product-highlight-text-block-{{ ai_gen_id }} {
      order: 2;
    }

    .ai-product-highlight-product-{{ ai_gen_id }} {
      order: 1;
    }

    .ai-product-highlight-text-block-{{ ai_gen_id }}:nth-child(3) {
      order: 3;
    }
  }
{% endstyle %}<product-highlight-{{ ai_gen_id }}
  class="ai-product-highlight-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-product-highlight-container-{{ ai_gen_id }}">
    <div class="ai-product-highlight-text-block-{{ ai_gen_id }}">
      {% if block.settings.left_heading != blank %}
        <h3>{{ block.settings.left_heading }}</h3>
      {% endif %}
      {% if block.settings.left_text != blank %}
        <div class="ai-product-highlight-text-{{ ai_gen_id }}">
          {{ block.settings.left_text }}
        </div>
      {% endif %}</div>

    <div class="ai-product-highlight-product-{{ ai_gen_id }}">
      <div class="ai-product-highlight-product-card-{{ ai_gen_id }}">
        {% if block.settings.featured_product != blank %}
          {% assign product = block.settings.featured_product %}
          
          <div class="ai-product-highlight-image-wrapper-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 600}}"
                alt="{{ product.featured_image.alt | escape }}"
                class="ai-product-highlight-image-{{ ai_gen_id }}"
                loading="lazy"
                width="600"
                height="300"
              >
            {% else %}
              <div class="ai-product-highlight-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-apparel-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <h2 class="ai-product-highlight-product-title-{{ ai_gen_id }}">
            {{ product.title }}
          </h2>

          <div class="ai-product-highlight-product-price-{{ ai_gen_id }}">
            {{ product.price | money }}
          </div>

          {% if product.description != blank %}
            <div class="ai-product-highlight-product-description-{{ ai_gen_id }}">
              {{ product.description | strip_html | truncate: 120 }}
            </div>
          {% endif %}

          <a
            href="{{ product.url }}"
            class="ai-product-highlight-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
          </a>
        {% else %}
          <div class="ai-product-highlight-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-apparel-1' | placeholder_svg_tag }}
            <div class="ai-product-highlight-empty-state-{{ ai_gen_id }}">
              Select a featured product
            </div>
          </div>
          <div class="ai-product-highlight-empty-product-{{ ai_gen_id }}">
            Choose a product to highlight
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-product-highlight-text-block-{{ ai_gen_id }}">
      {% if block.settings.right_heading != blank %}
        <h3>{{ block.settings.right_heading }}</h3>
      {% endif %}
      {% if block.settings.right_text != blank %}
        <div class="ai-product-highlight-text-{{ ai_gen_id }}">
          {{ block.settings.right_text }}
        </div>
      {% endif %}
    </div>
  </div>
</product-highlight-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductHighlight{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.observer = null;
      }

      connectedCallback() {
        this.setupScrollObserver();
      }

      disconnectedCallback() {
        if (this.observer) {
          this.observer.disconnect();
        }
      }

      setupScrollObserver() {
        const options = {
          threshold: 0.2,
          rootMargin: '0px 0px -10% 0px'
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        }, options);

        const elementsToObserve = this.querySelectorAll(
          '.ai-product-highlight-text-block-{{ ai_gen_id }}, .ai-product-highlight-product-{{ ai_gen_id }}'
        );

        elementsToObserve.forEach(element => {
          this.observer.observe(element);
        });
      }
    }

    customElements.define('product-highlight-{{ ai_gen_id }}', ProductHighlight{{ ai_gen_id }});
  })();
</script>

