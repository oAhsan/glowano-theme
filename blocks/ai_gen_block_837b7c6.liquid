{% doc %}
  @prompt
    Create a custom Shopify section for a banner image with two clickable animated hotspots. The hotspots must have a radiating  and pulsing animation effect to draw attention. When a hotspot is clicked, a sleek slide-in product card should appear from the bottom of the screen. The card should show the product image, title, price, and an add-to-cart button. Both the product image and title must also be clickable and link to the product page. The card should close when tapping outside the card area or pressing the close button, so scrolling can continue without interruption. In the theme editor, allow customization of the banner image, hotspot positions (x, y), and assigned products, as well as card background color, text size, and button style. Below the banner image, include a customizable rich text area for brand messaging or product highlights.

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-hotspots-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: 100%;
  }

  .ai-banner-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-banner-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 400px;
  }

  .ai-banner-hotspot-{{ ai_gen_id }} {
    position: absolute;
    top: var(--ai-hotspot-y-{{ ai_gen_id }});
    left: var(--ai-hotspot-x-{{ ai_gen_id }});
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .ai-banner-hotspot-button-{{ ai_gen_id }} {
    width: {{ block.settings.hotspot_size }}px;
    height: {{ block.settings.hotspot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.hotspot_color }};
    border: none;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: {{ block.settings.hotspot_icon_color }};
    position: relative;
    animation: ai-hotspot-pulse-{{ ai_gen_id }} 2s infinite;
  }

  .ai-banner-hotspot-button-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background-color: {{ block.settings.hotspot_color }};
    transform: translate(-50%, -50%);
    animation: ai-hotspot-ripple-{{ ai_gen_id }} 2s infinite;
    opacity: 0.6;
  }

  .ai-banner-hotspot-button-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.hotspot_size }}px * 0.5);
    height: calc({{ block.settings.hotspot_size }}px * 0.5);
    position: relative;
    z-index: 1;
  }

  @keyframes ai-hotspot-pulse-{{ ai_gen_id }} {
    0%, 100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.1);
    }
  }

  @keyframes ai-hotspot-ripple-{{ ai_gen_id }} {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0.6;
    }
    100% {
      transform: translate(-50%, -50%) scale(2);
      opacity: 0;
    }
  }

  .ai-banner-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-banner-overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-banner-product-card-{{ ai_gen_id }} {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background-color: {{ block.settings.card_bg_color }};
    border-radius: 16px 16px 0 0;
    padding: 24px;
    z-index: 1001;
    transform: translateY(100%);
    transition: transform 0.3s ease;
    max-height: 80vh;
    overflow-y: auto;
  }

  .ai-banner-product-card-{{ ai_gen_id }}.active {
    transform: translateY(0);
  }

  .ai-banner-card-header-{{ ai_gen_id }} {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .ai-banner-card-close-{{ ai_gen_id }} {
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.card_text_color }};
    opacity: 0.7;
  }

  .ai-banner-card-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-banner-card-content-{{ ai_gen_id }} {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
  }

  .ai-banner-card-image-{{ ai_gen_id }} {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
  }

  .ai-banner-card-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 8px;
  }

  .ai-banner-card-info-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-banner-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
    color: {{ block.settings.card_text_color }};
    text-decoration: none;
  }

  .ai-banner-card-title-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-banner-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_text_size }}px;
    margin-bottom: 16px;
    color: {{ block.settings.card_text_color }};
  }

  .ai-banner-card-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 24px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.card_text_size }}px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-banner-card-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-banner-empty-product-{{ ai_gen_id }} {
    text-align: center;
    color: #999;
    font-style: italic;
    padding: 20px;
  }

  .ai-banner-rich-text-{{ ai_gen_id }} {
    margin-top: 32px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  @media screen and (max-width: 749px) {
    .ai-banner-hotspot-button-{{ ai_gen_id }} {
      width: {{ block.settings.hotspot_size | times: 0.8 }}px;
      height: {{ block.settings.hotspot_size | times: 0.8 }}px;
    }

    .ai-banner-card-content-{{ ai_gen_id }} {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .ai-banner-card-image-{{ ai_gen_id }} {
      width: 100px;
      height: 100px;
    }
  }
{% endstyle %}

<banner-hotspots-{{ ai_gen_id }}
  class="ai-banner-hotspots-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-banner-image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.banner_image %}
      <img
        src="{{ block.settings.banner_image | image_url: width: 2000 }}"
        alt="{{ block.settings.banner_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.banner_image.width }}"
        height="{{ block.settings.banner_image.height }}"
      >
    {% else %}
      <div class="ai-banner-image-placeholder-{{ ai_gen_id }}">
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
        <div class="ai-banner-empty-state-{{ ai_gen_id }}">
          Add a banner image to get started
        </div>
      </div>
    {% endif %}

    {% for i in (1..2) %}
      {% liquid
        assign hotspot_enabled_key = 'hotspot_' | append: i | append: '_enabled'
        assign hotspot_x_key = 'hotspot_' | append: i | append: '_x'
        assign hotspot_y_key = 'hotspot_' | append: i | append: '_y'
        assign product_key = 'hotspot_' | append: i | append: '_product'

        assign hotspot_enabled = block.settings[hotspot_enabled_key]
        assign hotspot_x = block.settings[hotspot_x_key]
        assign hotspot_y = block.settings[hotspot_y_key]
        assign product = block.settings[product_key]
      %}

      {% if hotspot_enabled %}
        <div
          class="ai-banner-hotspot-{{ ai_gen_id }}"
          style="
            --ai-hotspot-x-{{ ai_gen_id }}: {{ hotspot_x }}%;
            --ai-hotspot-y-{{ ai_gen_id }}: {{ hotspot_y }}%;
          "
          data-hotspot-id="{{ i }}"
          data-product-id="{{ product.id }}"
        >
          <button
            class="ai-banner-hotspot-button-{{ ai_gen_id }}"
            aria-label="View product details"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="12" y1="5" x2="12" y2="19"></line>
              <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
          </button>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  {% if block.settings.rich_text != blank %}
    <div class="ai-banner-rich-text-{{ ai_gen_id }}">
      {{ block.settings.rich_text }}
    </div>
  {% endif %}

  <div class="ai-banner-overlay-{{ ai_gen_id }}"></div>

  <div class="ai-banner-product-card-{{ ai_gen_id }}">
    <div class="ai-banner-card-header-{{ ai_gen_id }}">
      <div></div>
      <button class="ai-banner-card-close-{{ ai_gen_id }}" aria-label="Close">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="ai-banner-card-content-{{ ai_gen_id }}">
      <div class="ai-banner-card-image-{{ ai_gen_id }}">
        <img src="" alt="" class="ai-banner-card-product-image-{{ ai_gen_id }}">
      </div>
      <div class="ai-banner-card-info-{{ ai_gen_id }}">
        <a href="" class="ai-banner-card-title-{{ ai_gen_id }}"></a>
        <div class="ai-banner-card-price-{{ ai_gen_id }}"></div>
      </div>
    </div>
    <button class="ai-banner-card-button-{{ ai_gen_id }}">Add to Cart</button>
  </div>

  <script type="application/json" data-product-data>
    {
      {% for i in (1..2) %}
        {% liquid
          assign product_key = 'hotspot_' | append: i | append: '_product'
          assign product = block.settings[product_key]
        %}
        {% if product != blank %}
          "{{ i }}": {
            "id": {{ product.id }},
            "title": {{ product.title | json }},
            "price": {{ product.price | money | json }},
            "url": {{ product.url | json }},
            "image": {% if product.featured_image %}{{ product.featured_image | image_url: width: 300 | json }}{% else %}""{% endif %},
            "image_alt": {% if product.featured_image %}{{ product.featured_image.alt | json }}{% else %}""{% endif %},
            "variant_id": {{ product.selected_or_first_available_variant.id }},
            "available": {{ product.available }}
          }{% unless forloop.last %},{% endunless %}
        {% endif %}
      {% endfor %}
    }
  </script>
</banner-hotspots-{{ ai_gen_id }}>

<script>
  (function() {
    class BannerHotspots{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.productData = {};
      }

      connectedCallback() {
        this.loadProductData();
        this.setupEventListeners();
      }

      loadProductData() {
        const dataScript = this.querySelector('[data-product-data]');
        if (dataScript) {
          try {
            this.productData = JSON.parse(dataScript.textContent);
          } catch (e) {
            console.error('Failed to parse product data:', e);
          }
        }
      }

      setupEventListeners() {
        const hotspots = this.querySelectorAll('.ai-banner-hotspot-{{ ai_gen_id }}');
        const overlay = this.querySelector('.ai-banner-overlay-{{ ai_gen_id }}');
        const productCard = this.querySelector('.ai-banner-product-card-{{ ai_gen_id }}');
        const closeButton = this.querySelector('.ai-banner-card-close-{{ ai_gen_id }}');
        const addToCartButton = this.querySelector('.ai-banner-card-button-{{ ai_gen_id }}');

        hotspots.forEach((hotspot) => {
          const button = hotspot.querySelector('.ai-banner-hotspot-button-{{ ai_gen_id }}');
          button.addEventListener('click', () => {
            const hotspotId = hotspot.dataset.hotspotId;
            this.showProductCard(hotspotId);
          });
        });

        closeButton.addEventListener('click', () => {
          this.hideProductCard();
        });

        overlay.addEventListener('click', () => {
          this.hideProductCard();
        });

        addToCartButton.addEventListener('click', () => {
          this.addToCart();
        });
      }

      showProductCard(hotspotId) {
        const product = this.productData[hotspotId];
        if (!product) {
          this.showEmptyProduct();
          return;
        }

        const productCard = this.querySelector('.ai-banner-product-card-{{ ai_gen_id }}');
        const overlay = this.querySelector('.ai-banner-overlay-{{ ai_gen_id }}');
        const image = this.querySelector('.ai-banner-card-product-image-{{ ai_gen_id }}');
        const title = this.querySelector('.ai-banner-card-title-{{ ai_gen_id }}');
        const price = this.querySelector('.ai-banner-card-price-{{ ai_gen_id }}');
        const addToCartButton = this.querySelector('.ai-banner-card-button-{{ ai_gen_id }}');

        image.src = product.image || '';
        image.alt = product.image_alt || product.title;
        title.textContent = product.title;
        title.href = product.url;
        price.textContent = product.price;

        addToCartButton.dataset.variantId = product.variant_id;
        addToCartButton.disabled = !product.available;
        addToCartButton.textContent = product.available ? 'Add to Cart' : 'Sold Out';

        overlay.classList.add('active');
        productCard.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      showEmptyProduct() {
        const productCard = this.querySelector('.ai-banner-product-card-{{ ai_gen_id }}');
        const overlay = this.querySelector('.ai-banner-overlay-{{ ai_gen_id }}');
        const content = this.querySelector('.ai-banner-card-content-{{ ai_gen_id }}');
        const addToCartButton = this.querySelector('.ai-banner-card-button-{{ ai_gen_id }}');

        content.innerHTML = '<div class="ai-banner-empty-product-{{ ai_gen_id }}">Select a product for this hotspot</div>';
        addToCartButton.style.display = 'none';

        overlay.classList.add('active');
        productCard.classList.add('active');
        document.body.style.overflow = 'hidden';
      }

      hideProductCard() {
        const productCard = this.querySelector('.ai-banner-product-card-{{ ai_gen_id }}');
        const overlay = this.querySelector('.ai-banner-overlay-{{ ai_gen_id }}');

        overlay.classList.remove('active');
        productCard.classList.remove('active');
        document.body.style.overflow = '';
      }

      addToCart() {
        const addToCartButton = this.querySelector('.ai-banner-card-button-{{ ai_gen_id }}');
        const variantId = addToCartButton.dataset.variantId;

        if (!variantId) return;

        const formData = new FormData();
        formData.append('id', variantId);
        formData.append('quantity', '1');

        fetch('/cart/add.js', {
          method: 'POST',
          body: formData
        })
        .then(response => response.json())
        .then(data => {
          this.hideProductCard();
          window.dispatchEvent(new CustomEvent('cart:updated'));
        })
        .catch(error => {
          console.error('Error adding to cart:', error);
        });
      }
    }

    customElements.define('banner-hotspots-{{ ai_gen_id }}', BannerHotspots{{ ai_gen_id }});
  })();
</script>

