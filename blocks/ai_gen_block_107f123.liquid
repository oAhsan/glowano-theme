{% doc %}
  @prompt
    Create a modern TikTok-style video carousel that displays multiple short videos in a horizontal slider.
    
    Only the center video should play automatically, while the others are paused.
    
    When the user interacts (clicks or taps) on a side video, it should smoothly slide to the center and start playing automatically.
    
    Each video should have two small round buttons overlaid at the bottom left corner — one for Play/Pause and one for Mute/Unmute.
    
    Add two arrow buttons (left and right) outside the carousel to manually switch between videos.
    
    The design should be clean, minimal, and rounded, with soft shadows and smooth animations.
    
    The section should work responsively on both desktop and mobile., accept all links, allow me to add as many vids i want, dont allow multiple vids to play at once and if i mute a single vid all of the vid should go mute, also make this section highly customizable , place the navigation buttons below the currousel at center, also only allow the vid to play at center, and give control to arrange the vids as my liking, make the first vid- to pop up of display order 5 means around center, instead of link it should allow me to use vids uploaded in shopify files library
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-carousel-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-carousel-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-video-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    margin-bottom: 30px;
  }

  .ai-video-carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.video_gap }}px;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 20px 0;
  }

  .ai-video-carousel-slide-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.video_width }}px;
    position: relative;
    cursor: pointer;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .ai-video-carousel-slide-{{ ai_gen_id }}:not(.active) {
    opacity: {{ block.settings.inactive_opacity | divided_by: 100.0 }};
    transform: scale({{ block.settings.inactive_scale | divided_by: 100.0 }});
  }

  .ai-video-carousel-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    transform: scale(1);
  }

  .ai-video-carousel-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.video_height }}px;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    background-color: #000;
  }

  .ai-video-carousel-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-video-carousel-controls-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.controls_bottom_offset }}px;
    left: {{ block.settings.controls_left_offset }}px;
    display: flex;
    gap: 10px;
    z-index: 10;
  }

  .ai-video-carousel-control-btn-{{ ai_gen_id }} {
    width: {{ block.settings.control_button_size }}px;
    height: {{ block.settings.control_button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.control_bg_color }};
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease;
    padding: 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .ai-video-carousel-control-btn-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
    background-color: {{ block.settings.control_bg_hover_color }};
  }

  .ai-video-carousel-control-btn-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.control_button_size }}px * 0.5);
    height: calc({{ block.settings.control_button_size }}px * 0.5);
    fill: {{ block.settings.control_icon_color }};
  }

  .ai-video-carousel-navigation-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
  }

  .ai-video-carousel-nav-btn-{{ ai_gen_id }} {
    width: {{ block.settings.nav_button_size }}px;
    height: {{ block.settings.nav_button_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_bg_color }};
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: transform 0.2s ease, background-color 0.2s ease;
    padding: 0;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-video-carousel-nav-btn-{{ ai_gen_id }}:hover:not(:disabled) {
    transform: scale(1.1);
    background-color: {{ block.settings.nav_bg_hover_color }};
  }

  .ai-video-carousel-nav-btn-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-video-carousel-nav-btn-{{ ai_gen_id }} svg {
    width: calc({{ block.settings.nav_button_size }}px * 0.4);
    height: calc({{ block.settings.nav_button_size }}px * 0.4);
    fill: {{ block.settings.nav_icon_color }};
  }

  .ai-video-carousel-counter-{{ ai_gen_id }} {
    font-size: {{ block.settings.counter_font_size }}px;
    color: {{ block.settings.counter_color }};
    font-weight: 500;
    min-width: 60px;
    text-align: center;
  }

  .ai-video-carousel-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 14px;
    text-align: center;
    padding: 20px;
  }

  @media screen and (max-width: 749px) {
    .ai-video-carousel-slide-{{ ai_gen_id }} {
      width: {{ block.settings.video_width_mobile }}px;
    }

    .ai-video-carousel-video-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.video_height_mobile }}px;
    }

    .ai-video-carousel-track-{{ ai_gen_id }} {
      gap: {{ block.settings.video_gap_mobile }}px;
    }
  }
{% endstyle %}

<video-carousel-{{ ai_gen_id }}
  class="ai-video-carousel-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-autoplay="{{ block.settings.autoplay_center }}"
>
  <div class="ai-video-carousel-container-{{ ai_gen_id }}">
    <div class="ai-video-carousel-wrapper-{{ ai_gen_id }}">
      <div class="ai-video-carousel-track-{{ ai_gen_id }}">
        {% if block.settings.videos != blank %}
          {% assign videos_array = block.settings.videos | split: ',' %}
          {% for video_url in videos_array %}
            {% assign trimmed_url = video_url | strip %}
            {% if trimmed_url != blank %}
              <div class="ai-video-carousel-slide-{{ ai_gen_id }}" data-index="{{ forloop.index0 }}">
                <div class="ai-video-carousel-video-wrapper-{{ ai_gen_id }}">
                  <video
                    class="ai-video-carousel-video-{{ ai_gen_id }}"
                    src="{{ trimmed_url }}"
                    playsinline
                    loop
                    {% if block.settings.muted_by_default %}muted{% endif %}
                    preload="metadata"
                  ></video>
                  <div class="ai-video-carousel-controls-{{ ai_gen_id }}">
                    <button
                      class="ai-video-carousel-control-btn-{{ ai_gen_id }} play-pause-btn"
                      aria-label="Play/Pause"
                    >
                      <svg class="play-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                      <svg class="pause-icon" style="display: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M6 4h4v16H6V4zm8 0h4v16h-4V4z"/>
                      </svg>
                    </button>
                    <button
                      class="ai-video-carousel-control-btn-{{ ai_gen_id }} mute-btn"
                      aria-label="Mute/Unmute"
                    >
                      <svg class="unmute-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
                      </svg>
                      <svg class="mute-icon" style="display: none;" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
                      </svg>
                    </button>
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        {% else %}
          {% for i in (1..5) %}
            <div class="ai-video-carousel-slide-{{ ai_gen_id }}" data-index="{{ forloop.index0 }}">
              <div class="ai-video-carousel-video-wrapper-{{ ai_gen_id }}">
                <div class="ai-video-carousel-placeholder-{{ ai_gen_id }}">
                  Add video URLs in settings
                </div>
              </div>
            </div>
          {% endfor %}
        {% endif %}
      </div>
    </div>

    <div class="ai-video-carousel-navigation-{{ ai_gen_id }}">
      <button
        class="ai-video-carousel-nav-btn-{{ ai_gen_id }} prev-btn"
        aria-label="Previous video"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
        </svg>
      </button>
      <div class="ai-video-carousel-counter-{{ ai_gen_id }}">
        <span class="current">1</span> / <span class="total">5</span>
      </div>
      <button
        class="ai-video-carousel-nav-btn-{{ ai_gen_id }} next-btn"
        aria-label="Next video"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M10 6L8.59 7.41 13.17 12l-4.58 4.59L10 18l6-6z"/>
        </svg>
      </button>
    </div>
  </div>
</video-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = {{ block.settings.initial_video_index | minus: 1 }};
        this.slides = [];
        this.videos = [];
        this.track = null;
        this.prevBtn = null;
        this.nextBtn = null;
        this.currentCounter = null;
        this.totalCounter = null;
        this.globalMuted = {{ block.settings.muted_by_default | json }};
        this.autoplay = this.dataset.autoplay === 'true';
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-video-carousel-track-{{ ai_gen_id }}');
        this.slides = Array.from(this.querySelectorAll('.ai-video-carousel-slide-{{ ai_gen_id }}'));
        this.videos = Array.from(this.querySelectorAll('.ai-video-carousel-video-{{ ai_gen_id }}'));
        this.prevBtn = this.querySelector('.prev-btn');
        this.nextBtn = this.querySelector('.next-btn');
        this.currentCounter = this.querySelector('.current');
        this.totalCounter = this.querySelector('.total');

        if (this.slides.length === 0) return;

        this.totalCounter.textContent = this.slides.length;
        this.setupEventListeners();
        this.updateCarousel();
      }

      setupEventListeners() {
        this.prevBtn.addEventListener('click', () => this.navigate(-1));
        this.nextBtn.addEventListener('click', () => this.navigate(1));

        this.slides.forEach((slide, index) => {
          slide.addEventListener('click', () => {
            if (index !== this.currentIndex) {
              this.currentIndex = index;
              this.updateCarousel();
            }
          });

          const video = slide.querySelector('.ai-video-carousel-video-{{ ai_gen_id }}');
          const playPauseBtn = slide.querySelector('.play-pause-btn');
          const muteBtn = slide.querySelector('.mute-btn');

          if (playPauseBtn && video) {
            playPauseBtn.addEventListener('click', (e) => {
              e.stopPropagation();
              this.togglePlayPause(video, playPauseBtn);
            });
          }

          if (muteBtn && video) {
            muteBtn.addEventListener('click', (e) => {
              e.stopPropagation();
              this.toggleMuteAll();
            });
          }
        });
      }

      navigate(direction) {
        const newIndex = this.currentIndex + direction;
        if (newIndex >= 0 && newIndex < this.slides.length) {
          this.currentIndex = newIndex;
          this.updateCarousel();
        }
      }

      updateCarousel() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.video_gap }};
        const containerWidth = this.track.parentElement.offsetWidth;
        const centerOffset = (containerWidth - slideWidth) / 2;
        const offset = -(this.currentIndex * (slideWidth + gap)) + centerOffset;

        this.track.style.transform = `translateX(${offset}px)`;

        this.slides.forEach((slide, index) => {
          if (index === this.currentIndex) {
            slide.classList.add('active');
          } else {
            slide.classList.remove('active');
          }
        });

        this.videos.forEach((video, index) => {
          if (index === this.currentIndex) {
            if (this.autoplay) {
              video.play().catch(() => {});
            }
            this.updatePlayPauseIcon(video);
          } else {
            video.pause();
            this.updatePlayPauseIcon(video);
          }
        });

        this.currentCounter.textContent = this.currentIndex + 1;
        this.prevBtn.disabled = this.currentIndex === 0;
        this.nextBtn.disabled = this.currentIndex === this.slides.length - 1;
      }

      togglePlayPause(video, button) {
        if (video.paused) {
          video.play().catch(() => {});
        } else {
          video.pause();
        }
        this.updatePlayPauseIcon(video, button);
      }

      updatePlayPauseIcon(video, button) {
        const slide = video.closest('.ai-video-carousel-slide-{{ ai_gen_id }}');
        const btn = button || slide.querySelector('.play-pause-btn');
        const playIcon = btn.querySelector('.play-icon');
        const pauseIcon = btn.querySelector('.pause-icon');

        if (video.paused) {
          playIcon.style.display = 'block';
          pauseIcon.style.display = 'none';
        } else {
          playIcon.style.display = 'none';
          pauseIcon.style.display = 'block';
        }
      }

      toggleMuteAll() {
        this.globalMuted = !this.globalMuted;
        this.videos.forEach((video) => {
          video.muted = this.globalMuted;
          this.updateMuteIcon(video);
        });
      }

      updateMuteIcon(video) {
        const slide = video.closest('.ai-video-carousel-slide-{{ ai_gen_id }}');
        const muteBtn = slide.querySelector('.mute-btn');
        const unmuteIcon = muteBtn.querySelector('.unmute-icon');
        const muteIcon = muteBtn.querySelector('.mute-icon');

        if (video.muted) {
          unmuteIcon.style.display = 'none';
          muteIcon.style.display = 'block';
        } else {
          unmuteIcon.style.display = 'block';
          muteIcon.style.display = 'none';
        }
      }
    }

    customElements.define('video-carousel-{{ ai_gen_id }}', VideoCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "TikTok video carousel",
  "settings": [
    {
      "type": "header",
      "content": "Videos"
    },
    {
      "type": "textarea",
      "id": "videos",
      "label": "Video URLs",
      "info": "Add video URLs from Shopify Files, separated by commas. Example: https://cdn.shopify.com/videos/video1.mp4, https://cdn.shopify.com/videos/video2.mp4"
    },
    {
      "type": "range",
      "id": "initial_video_index",
      "min": 1,
      "max": 20,
      "step": 1,
      "label": "Initial video position",
      "default": 5,
      "info": "Which video to show first (display order)"
    },
    {
      "type": "checkbox",
      "id": "autoplay_center",
      "label": "Autoplay center video",
      "default": true
    },
    {
      "type": "checkbox",
