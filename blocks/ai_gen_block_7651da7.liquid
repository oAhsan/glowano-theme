{% doc %}
  @prompt
    Create a custom Shopify section for a banner image with two clickable animated hotspots.
    
    Hotspots should have a subtle pulsing animation to attract attention without being distracting.
    
    When a hotspot is clicked, a sleek slide-in product card should appear from the bottom of the screen.
    
    The slide-in card must include:
    
    Product image (average/medium size, not fullscreen).  (must be clickable directing to the appropriate
    product link)
    
    Product title. (must be clickable directing to the appropriate
    product link)
    Product price.
    
    See product button.  (must be clickable directing to the appropriate
    product link)
    
    A close  button in the top-right of the card.
    
    the card should close by tapping anywhere outside the card. or swiping anywhere outside the card
    
    Both the product image and the product title should be clickable links to the product page.
    
    Theme editor customization options:
    
    Banner background image.
    
    Hotspot positions (x, y).
    
    Assign products to hotspots.
    
    Background color, text size, button style for the card.
    
    Behavior:
    
    Hotspots must stay fixed in position on the banner, even when resizing the screen., the hotspots must be pulsing radiating but simple and sleek, also give control to increase or decrease the size of plus icon inside the hotspot,                               in the prduct card give control to increase the size of image, i should not pulse rings and radiate this extremely, i want the hotspot to pulse simple looking clean, Update the hotspot animation so that it pulses softly, with a gentle scale effect (about 1.1x) and a smooth glow. The animation should feel like a calm breathing effect instead of a sharp bounce. Keep the color, size, and positioning of the hotspots the same., increase the plus icon size in hotspot and keep everything the same, hotspot should have a soft ripple pulse effect (like outward waves). take back the control of increasing plus icon make it moderate and make the hotspot size customization more flexible                        Prevent the page from zooming or shifting when the popup is open., Hotspots should have a soft outward breathing pulse animation only (no shrinking back in)., there should be no ripple in the hotspot but a soft breathing out, animation should be like breathing coming out only dont increasev the size of hotspot instead it emits something of low opacity light but clean minimalistic, decrease the radius of emmiting light and increase speed, assign customization to increasing radius

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-banner-hotspots-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.banner_height }}px;
    overflow: hidden;
  }

  .ai-banner-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-banner-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 300px;
    opacity: 0.3;
  }

  .ai-banner-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 6px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-hotspot-{{ ai_gen_id }} {
    position: absolute;
    top: var(--hotspot-y);
    left: var(--hotspot-x);
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .ai-hotspot-button-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.hotspot_size }}px;
    height: {{ block.settings.hotspot_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.hotspot_color }};
    border: 2px solid {{ block.settings.hotspot_border_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: {{ block.settings.hotspot_icon_color }};
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    transition: transform 0.3s ease;
  }

  .ai-hotspot-button-{{ ai_gen_id }}:hover {
    transform: scale(1.1);
  }

  .ai-hotspot-button-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    background-color: {{ block.settings.hotspot_glow_color }};
    transform: translate(-50%, -50%);
    opacity: 0;
    animation: ai-hotspot-breathe-glow-{{ ai_gen_id }} {{ block.settings.pulse_speed }}s ease-out infinite;
    pointer-events: none;
  }

  .ai-hotspot-button-{{ ai_gen_id }} svg {
    width: 18px;
    height: 18px;
    stroke-width: 2.5;
    position: relative;
    z-index: 1;
  }

  @keyframes ai-hotspot-breathe-glow-{{ ai_gen_id }} {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 0;
    }
    30% {
      opacity: {{ block.settings.glow_opacity | divided_by: 100.0 }};
    }
    100% {
      transform: translate(-50%, -50%) scale({{ block.settings.glow_radius | divided_by: 10.0 }});
      opacity: 0;
    }
  }

  .ai-product-card-overlay-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-product-card-overlay-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-product-card-{{ ai_gen_id }} {
    position: fixed;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(100%);
    width: 90%;
    max-width: 400px;
    background-color: {{ block.settings.card_background_color }};
    border-radius: 16px 16px 0 0;
    padding: 24px;
    z-index: 1001;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.15);
  }

  .ai-product-card-{{ ai_gen_id }}.active {
    transform: translateX(-50%) translateY(0);
  }

  .ai-product-card-close-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: {{ block.settings.card_text_color }};
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .ai-product-card-close-{{ ai_gen_id }}:hover {
    opacity: 1;
  }

  .ai-product-card-close-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-product-card-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 20px;
  }

  .ai-product-image-{{ ai_gen_id }} {
    width: {{ block.settings.card_image_size }}px;
    height: {{ block.settings.card_image_size }}px;
    margin: 0 auto;
    border-radius: 8px;
    overflow: hidden;transition: transform 0.3s ease;
  }

  .ai-product-image-{{ ai_gen_id }}:hover {
    transform: scale(1.02);
  }

  .ai-product-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;display: block;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-image-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.5;
  }

  .ai-product-info-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    font-weight: 600;
    color: {{ block.settings.card_text_color }};
    margin: 0 0 8px;text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .ai-product-title-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_price_size }}px;
    color: {{ block.settings.card_text_color }};
    margin-bottom: 16px;
    opacity: 0.8;
  }

  .ai-product-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 12px 24px;
    background-color: {{ block.settings.card_button_color }};
    color: {{ block.settings.card_button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.card_button_radius }}px;
    font-size: {{ block.settings.card_button_size }}px;
    font-weight: 500;
    transition: background-color 0.3s ease, transform 0.2s ease;
    text-align: center;
  }

  .ai-product-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.card_button_hover_color }};
    transform: translateY(-1px);
  }

  .ai-product-empty-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.card_text_color }};
    opacity: 0.6;
    font-style: italic;
    padding: 20px;
  }

  body.ai-modal-open-{{ ai_gen_id }} {
    overflow: hidden;
    position: fixed;
    width: 100%;
    height: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-hotspot-button-{{ ai_gen_id }} {
      width: calc({{ block.settings.hotspot_size }}px * 0.85);
      height: calc({{ block.settings.hotspot_size }}px * 0.85);
    }

    .ai-hotspot-button-{{ ai_gen_id }} svg {
      width: 16px;
      height: 16px;
    }

    .ai-product-card-{{ ai_gen_id }} {
      width: 95%;
      padding: 20px;
    }

    .ai-product-image-{{ ai_gen_id }} {
      width: calc({{ block.settings.card_image_size }}px * 0.8);
      height: calc({{ block.settings.card_image_size }}px * 0.8);
    }
  }
{% endstyle %}

<banner-hotspots-{{ ai_gen_id }}
  class="ai-banner-hotspots-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.banner_image %}
    <img
      src="{{ block.settings.banner_image | image_url: width: 2000 }}"
      alt="{{ block.settings.banner_image.alt | escape }}"
      class="ai-banner-image-{{ ai_gen_id }}"
      loading="lazy"
      width="{{ block.settings.banner_image.width }}"
      height="{{ block.settings.banner_image.height }}"
    >
  {% else %}
    <div class="ai-banner-placeholder-{{ ai_gen_id }}">
      {{ 'hero-apparel-1' | placeholder_svg_tag }}<div class="ai-banner-empty-state-{{ ai_gen_id }}">
        Add a banner image to get started
      </div>
    </div>
  {% endif %}

  {% for i in (1..2) %}
    {% liquid
      assign hotspot_enabled_key = 'hotspot_' | append: i | append: '_enabled'
      assign hotspot_x_key = 'hotspot_' | append: i | append: '_x'
      assign hotspot_y_key = 'hotspot_' | append: i | append: '_y'
      assign product_key = 'hotspot_' | append: i | append: '_product'

      assign hotspot_enabled = block.settings[hotspot_enabled_key]
      assign hotspot_x = block.settings[hotspot_x_key]
      assign hotspot_y = block.settings[hotspot_y_key]
      assign product = block.settings[product_key]
    %}

    {% if hotspot_enabled %}
      <div
        class="ai-hotspot-{{ ai_gen_id }}"
        style="--hotspot-x: {{ hotspot_x }}%; --hotspot-y: {{ hotspot_y }}%;"
        data-hotspot-id="{{ i }}"
      >
        <button
          class="ai-hotspot-button-{{ ai_gen_id }}"
          aria-label="View product details"
          data-product-id="{{ product.id }}">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
        </button>
      </div>
    {% endif %}
  {% endfor %}

  <div class="ai-product-card-overlay-{{ ai_gen_id }}" data-overlay></div>

  {% for i in (1..2) %}
    {% liquid
      assign product_key = 'hotspot_' | append: i | append: '_product'
      assign product = block.settings[product_key]
    %}

    <div
      class="ai-product-card-{{ ai_gen_id }}"
      data-card-id="{{ i }}"
    >
      <button
        class="ai-product-card-close-{{ ai_gen_id }}"
        aria-label="Close product card"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="ai-product-card-content-{{ ai_gen_id }}">
        {% if product != blank %}
          <a href="{{ product.url }}" class="ai-product-image-{{ ai_gen_id }}">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 400 }}"
                alt="{{ product.featured_image.alt | escape }}"
                width="400"
                height="400"
                loading="lazy"
              >
            {% else %}
              <div class="ai-product-image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </a>

          <div class="ai-product-info-{{ ai_gen_id }}">
            <a href="{{ product.url }}" class="ai-product-title-{{ ai_gen_id }}">
              {{ product.title }}
            </a>
            <div class="ai-product-price-{{ ai_gen_id }}">
              {{ product.price | money }}
            </div><a href="{{ product.url }}" class="ai-product-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          </div>
        {% else %}
          <div class="ai-product-empty-{{ ai_gen_id }}">
            Select a product for hotspot {{ i }}
          </div>
        {% endif %}
      </div>
    </div>
  {% endfor %}
</banner-hotspots-{{ ai_gen_id }}><script>
  (function() {
    class BannerHotspots{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.activeCard = null;
        this.startY = 0;
        this.currentY = 0;
        this.isDragging = false;
        this.scrollY = 0;
      }

      connectedCallback() {
        this.hotspots = this.querySelectorAll('.ai-hotspot-button-{{ ai_gen_id }}');
        this.cards = this.querySelectorAll('.ai-product-card-{{ ai_gen_id }}');
        this.overlay = this.querySelector('.ai-product-card-overlay-{{ ai_gen_id }}');
        this.closeButtons = this.querySelectorAll('.ai-product-card-close-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.hotspots.forEach((hotspot) => {
          hotspot.addEventListener('click', (e) => {
            const hotspotId = hotspot.closest('.ai-hotspot-{{ ai_gen_id }}').dataset.hotspotId;
            this.showCard(hotspotId);
          });
        });

        this.closeButtons.forEach((closeBtn) => {
          closeBtn.addEventListener('click', () => {
            this.hideCard();
          });
        });

        this.overlay.addEventListener('click', () => {
          this.hideCard();
        });

        this.cards.forEach((card) => {
          card.addEventListener('touchstart', (e) => {
            this.startY = e.touches[0].clientY;
            this.isDragging = false;
          }, { passive: true });

          card.addEventListener('touchmove', (e) => {
            this.currentY = e.touches[0].clientY;
            const deltaY = this.currentY - this.startY;
            
            if (deltaY > 10) {
              this.isDragging = true;
              const translateY = Math.max(0, deltaY);
              card.style.transform = `translateX(-50%) translateY(${translateY}px)`;
            }
          }, { passive: true });

          card.addEventListener('touchend', () => {
            if (this.isDragging) {
              const deltaY = this.currentY - this.startY;
              if (deltaY > 100) {
                this.hideCard();
              } else {
                card.style.transform = 'translateX(-50%) translateY(0)';
              }
            }
            this.isDragging = false;
          }, { passive: true });
        });document.addEventListener('click', (e) => {
          if (this.activeCard &&
              !e.target.closest('.ai-product-card-{{ ai_gen_id }}') &&
              !e.target.closest('.ai-hotspot-button-{{ ai_gen_id }}')) {
            this.hideCard();
          }
        });document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.activeCard) {
            this.hideCard();
          }
        });
      }

      showCard(hotspotId) {
        this.hideCard();
        
        const card = this.querySelector(`[data-card-id="${hotspotId}"]`);
        if (card) {
          this.activeCard = card;
          this.scrollY = window.scrollY;document.body.classList.add('ai-modal-open-{{ ai_gen_id }}');
          document.body.style.top = `-${this.scrollY}px`;
          
          this.overlay.classList.add('active');
          card.classList.add('active');}
      }

      hideCard() {
        if (this.activeCard) {
          this.activeCard.classList.remove('active');
          this.activeCard.style.transform = '';
          this.overlay.classList.remove('active');document.body.classList.remove('ai-modal-open-{{ ai_gen_id }}');
          document.body.style.top = '';
          window.scrollTo(0, this.scrollY);
          
          this.activeCard = null;}
      }
    }

    customElements.define('banner-hotspots-{{ ai_gen_id }}', BannerHotspots{{ ai_gen_id }});
  })();
</script>

