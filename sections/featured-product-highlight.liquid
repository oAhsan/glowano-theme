{% if section.settings.product == blank %}
  {% assign selected_product = all_products[section.settings.fallback_handle] %}
{% else %}
  {% assign selected_product = section.settings.product %}
{% endif %}

<section
  id="FeaturedProductHighlight-{{ section.id }}"
  class="section featured-highlight-section color-{{ section.settings.color_scheme }} gradient"
>
  <div class="section-{{ section.id }}-padding">
    {% render 'featured-product-highlight', section: section, product: selected_product %}
  </div>
</section>

{% schema %}
{
  "name": "Featured Product Highlight",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Highlight product",
      "info": "Choose the Glowano eyelash serum product to feature."
    },
    {
      "type": "text",
      "id": "fallback_handle",
      "label": "Fallback product handle",
      "info": "Optional. Used if no product is selected."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "Featured Product Highlight",
      "category": "Glowano"
    }
  ]
}
{% endschema %}

